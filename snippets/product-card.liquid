<article class="product-card card">
  <a class="product-card__media" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 900 | image_tag: widths: '360, 540, 720, 900', sizes: '(min-width: 900px) 30vw, (min-width: 640px) 45vw, 92vw', loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </a>
  <div class="product-card__content">
    {% unless product.available %}<span class="pill">Sold out</span>{% endunless %}
    <h3 class="product-card__title"><a href="{{ product.url }}">{{ product.title | escape }}</a></h3>
    {% render 'price', product: product %}
  </div>
</article>
