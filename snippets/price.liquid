{% liquid
  assign target = product.selected_or_first_available_variant | default: product
  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 0
%}
<div class="price" aria-live="polite">
  {% if compare_at_price > price %}<s>{{ compare_at_price | money }}</s>{% endif %}
  <span data-product-price>{{ price | money }}</span>
  {% if compare_at_price > price %}<span class="sale-badge">Save {{ compare_at_price | minus: price | money }}</span>{% endif %}
</div>
