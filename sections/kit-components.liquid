<section class="kit-components section-shell--compact" data-motion-section>
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
    <div class="rte">{{ section.settings.text }}</div>
  </div>
  <div class="kit-components__grid">
    {% for block in section.blocks %}
      <article class="component-card" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 70 }}ms;" {{ block.shopify_attributes }}>
        <div class="component-card__visual">
          <div class="component-card__asset" data-parallax="{{ block.settings.parallax }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 700 | image_tag: widths: '220, 360, 520, 700', sizes: '(min-width: 900px) 20vw, (min-width: 560px) 33vw, 46vw', loading: 'lazy', alt: block.settings.title }}
            {% elsif block.settings.asset != 'none' %}
              <img src="{{ block.settings.asset | asset_url }}" alt="{{ block.settings.title | escape }}" width="600" height="600" loading="lazy">
            {% else %}
              <div class="component-card__placeholder" aria-hidden="true"><span>{{ block.settings.symbol | escape }}</span></div>
            {% endif %}
          </div>
        </div>
        <div class="component-card__copy">
          <div class="component-card__top">
            <h3>{{ block.settings.title | escape }}</h3>
            <span class="component-card__tag">{{ block.settings.tag | escape }}</span>
          </div>
          <p>{{ block.settings.text | escape }}</p>
          <dl class="component-card__details">
            <div><dt>{{ block.settings.detail_1_label | escape }}</dt><dd>{{ block.settings.detail_1_value | escape }}</dd></div>
            <div><dt>{{ block.settings.detail_2_label | escape }}</dt><dd>{{ block.settings.detail_2_value | escape }}</dd></div>
          </dl>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .kit-components { position: relative; }
  .kit-components .section-heading { max-width: 940px; margin-bottom: 1.4rem; }
  .kit-components .section-heading h2 { max-width: 10ch; letter-spacing: -.04em; }
  .kit-components .section-heading .rte { max-width: 34ch; color: var(--muted); font-weight: 750; }
  .kit-components__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .8rem; }
  .component-card { min-width: 0; display: grid; grid-template-rows: auto 1fr; overflow: hidden; border: 1px solid rgba(7,10,13,.16); border-radius: 18px; background: rgba(255,253,246,.9); box-shadow: 0 18px 46px rgba(7,10,13,.09); transition: transform .24s cubic-bezier(.16,1,.3,1), box-shadow .24s cubic-bezier(.16,1,.3,1), border-color .24s ease; }
  .component-card__visual { min-height: 0; aspect-ratio: 1.18 / 1; display: grid; place-items: center; overflow: hidden; padding: .85rem; border-bottom: 1px solid rgba(7,10,13,.12); background: #dff7f6; }
  .component-card:nth-child(3n + 2) .component-card__visual { background: #fff0b8; }
  .component-card:nth-child(3n) .component-card__visual { background: #dcecff; }
  .component-card__asset { width: 100%; height: 100%; display: grid; place-items: center; transform: translate3d(0, var(--parallax-y, 0), 0); }
  .component-card__asset img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 16px 22px rgba(7,10,13,.24)); transition: scale .28s cubic-bezier(.16,1,.3,1), transform .28s cubic-bezier(.16,1,.3,1); }
  .component-card__copy { min-width: 0; display: grid; gap: .5rem; padding: .78rem .85rem .9rem; }
  .component-card__top { display: flex; align-items: start; justify-content: space-between; gap: .5rem; }
  .component-card__copy h3 { margin: 0; font-size: clamp(1rem, 1.45vw, 1.28rem); line-height: .98; letter-spacing: -.018em; }
  .component-card__copy p { margin: 0; color: var(--muted); font-size: .72rem; font-weight: 750; line-height: 1.25; }
  .component-card__tag { align-self: start; border-radius: 999px; padding: .28rem .48rem; background: var(--ink); color: white; font-size: .54rem; font-weight: 950; letter-spacing: .08em; line-height: 1; text-transform: uppercase; white-space: nowrap; }
  .component-card__details { display: grid; grid-template-columns: 1fr 1fr; gap: .4rem; margin: .15rem 0 0; }
  .component-card__details div { min-width: 0; border-radius: 12px; padding: .48rem .5rem; background: rgba(7,10,13,.045); }
  .component-card__details dt { color: var(--muted); font-size: .54rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
  .component-card__details dd { margin: .08rem 0 0; font-size: .68rem; font-weight: 900; line-height: 1.05; }
  .component-card__placeholder { width: 78px; height: 78px; display: grid; place-items: center; border: 2px solid var(--ink); border-radius: 50%; background: white; box-shadow: 0 16px 22px rgba(7,10,13,.14); }
  .component-card__placeholder span { font-family: var(--font-display-ui); font-size: 1.7rem; font-weight: 900; }
  @media (hover: hover) {
    .component-card:hover { transform: translateY(-6px); border-color: rgba(7,10,13,.3); box-shadow: 0 28px 72px rgba(7,10,13,.16); }
    .component-card:hover img { scale: 1.055; transform: translateY(-3px); }
  }
  @media (min-width: 680px) {
    .kit-components__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .component-card { grid-template-columns: minmax(132px, 34%) minmax(0, 1fr); grid-template-rows: none; }
    .component-card__visual { aspect-ratio: auto; border-right: 1px solid rgba(7,10,13,.12); border-bottom: 0; }
    .component-card__copy { align-content: center; }
  }
  @media (min-width: 1040px) {
    .kit-components__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .component-card { min-height: 0; grid-template-columns: 1fr; grid-template-rows: auto 1fr; }
    .component-card__visual { aspect-ratio: 1.18 / 1; border-right: 0; border-bottom: 1px solid rgba(7,10,13,.12); padding: 1rem; }
    .component-card__copy { min-height: 148px; align-content: start; }
  }
  @media (max-width: 520px) {
    .kit-components__grid { gap: .7rem; }
    .component-card { border-radius: 16px; }
    .component-card__visual { padding: .55rem; }
    .component-card__copy { padding: .65rem; gap: .42rem; }
    .component-card__copy p { display: none; }
    .component-card__details { grid-template-columns: 1fr; gap: .28rem; }
    .component-card__details div { padding: .38rem .42rem; }
    .component-card__details div:nth-child(2) { display: none; }
  }
  @media (max-width: 350px) {
    .component-card__copy h3 { font-size: .78rem; }
    .component-card__tag { font-size: .46rem; padding-inline: .36rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Kit components",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Inside the box" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick a part. Build a project." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>The BREADBOX hardware lineup, packed into one compact kit.</p>" }
  ],
  "blocks": [{
    "type": "component",
    "name": "Component",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Custom image" },
      { "type": "select", "id": "asset", "label": "Built-in image", "options": [
        { "value": "component-arduino-uno.png", "label": "Arduino UNO" },
        { "value": "component-breadboard.png", "label": "Mini breadboard" },
        { "value": "component-oled.png", "label": "OLED display" },
        { "value": "component-joystick.png", "label": "Joystick" },
        { "value": "component-mpu6050.png", "label": "MPU6050" },
        { "value": "component-servo.png", "label": "SG90 servo" },
        { "value": "component-button.png", "label": "Push button" },
        { "value": "component-buzzer.png", "label": "Passive buzzer" },
        { "value": "none", "label": "Graphic placeholder" }
      ], "default": "component-arduino-uno.png" },
      { "type": "text", "id": "symbol", "label": "Placeholder symbol", "default": "+" },
      { "type": "text", "id": "title", "label": "Name", "default": "Arduino UNO R3" },
      { "type": "text", "id": "text", "label": "Short description", "default": "The brain of every build" },
      { "type": "text", "id": "tag", "label": "Small tag", "default": "Core" },
      { "type": "text", "id": "detail_1_label", "label": "Detail 1 label", "default": "Type" },
      { "type": "text", "id": "detail_1_value", "label": "Detail 1 value", "default": "Controller" },
      { "type": "text", "id": "detail_2_label", "label": "Detail 2 label", "default": "Use" },
      { "type": "text", "id": "detail_2_value", "label": "Detail 2 value", "default": "Logic" },
      { "type": "range", "id": "parallax", "label": "Scroll movement", "min": -8, "max": 8, "step": 1, "default": 3 }
    ]
  }],
  "presets": [{
    "name": "Kit components",
    "blocks": [
      { "type": "component", "settings": { "asset": "component-arduino-uno.png", "title": "Arduino UNO R3", "text": "The brain of every build", "tag": "Core", "detail_1_label": "Type", "detail_1_value": "Controller", "detail_2_label": "Use", "detail_2_value": "Logic", "parallax": 3 } },
      { "type": "component", "settings": { "asset": "component-breadboard.png", "title": "Mini breadboard", "text": "Build without soldering", "tag": "Build", "detail_1_label": "Type", "detail_1_value": "Prototyping", "detail_2_label": "Use", "detail_2_value": "Wiring", "parallax": -3 } },
      { "type": "component", "settings": { "asset": "component-oled.png", "title": "SSD1306 OLED", "text": "Crisp graphics and games", "tag": "Screen", "detail_1_label": "Output", "detail_1_value": "Display", "detail_2_label": "Interface", "detail_2_value": "I2C", "parallax": 4 } },
      { "type": "component", "settings": { "asset": "component-joystick.png", "title": "Joystick module", "text": "Two-axis control", "tag": "Input", "detail_1_label": "Input", "detail_1_value": "Analog", "detail_2_label": "Use", "detail_2_value": "Control", "parallax": -2 } },
      { "type": "component", "settings": { "asset": "component-mpu6050.png", "title": "MPU6050", "text": "Motion and tilt sensing", "tag": "Motion", "detail_1_label": "Input", "detail_1_value": "IMU", "detail_2_label": "Use", "detail_2_value": "Tilt", "parallax": 4 } },
      { "type": "component", "settings": { "asset": "component-servo.png", "title": "SG90 servo", "text": "Make projects move", "tag": "Move", "detail_1_label": "Output", "detail_1_value": "Motion", "detail_2_label": "Use", "detail_2_value": "Actuate", "parallax": -4 } },
      { "type": "component", "settings": { "asset": "component-button.png", "symbol": "●", "title": "Push buttons", "text": "Simple tactile input", "tag": "Tap", "detail_1_label": "Input", "detail_1_value": "Digital", "detail_2_label": "Use", "detail_2_value": "Trigger", "parallax": 2 } },
      { "type": "component", "settings": { "asset": "component-buzzer.png", "symbol": "))", "title": "Passive buzzer", "text": "Sound and feedback", "tag": "Sound", "detail_1_label": "Output", "detail_1_value": "Audio", "detail_2_label": "Use", "detail_2_value": "Feedback", "parallax": -2 } }
    ]
  }]
}
{% endschema %}
