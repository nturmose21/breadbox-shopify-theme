<section class="kit-components section-shell--compact" data-motion-section>
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
    <div class="rte">{{ section.settings.text }}</div>
  </div>
  <div class="kit-components__grid">
    {% for block in section.blocks %}
      <article class="component-card" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 70 }}ms;" {{ block.shopify_attributes }}>
        <div class="component-card__visual">
          <div class="component-card__asset" data-parallax="{{ block.settings.parallax }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 700 | image_tag: widths: '220, 360, 520, 700', sizes: '(min-width: 900px) 20vw, (min-width: 560px) 33vw, 46vw', loading: 'lazy', alt: block.settings.title }}
            {% elsif block.settings.asset != 'none' %}
              <img src="{{ block.settings.asset | asset_url }}" alt="{{ block.settings.title | escape }}" width="600" height="600" loading="lazy">
            {% else %}
              <div class="component-card__placeholder" aria-hidden="true"><span>{{ block.settings.symbol | escape }}</span></div>
            {% endif %}
          </div>
        </div>
        <div class="component-card__copy"><h3>{{ block.settings.title | escape }}</h3><p>{{ block.settings.text | escape }}</p></div>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .kit-components { position: relative; }
  .kit-components .section-heading { max-width: 760px; margin-bottom: 1rem; }
  .kit-components .section-heading h2 { max-width: 12ch; }
  .kit-components__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .7rem; }
  .component-card { min-width: 0; display: grid; grid-template-rows: auto 1fr; overflow: hidden; border: 3px solid var(--ink); border-radius: var(--radius); background: var(--paper-bright); box-shadow: 3px 4px 0 var(--ink); transition: transform .18s ease, box-shadow .18s ease, background .18s ease; }
  .component-card__visual { min-height: 0; aspect-ratio: 1.18 / 1; display: grid; place-items: center; overflow: hidden; padding: .55rem; border-bottom: 3px solid var(--ink); background: #dff7f6; }
  .component-card:nth-child(3n + 2) .component-card__visual { background: #fff0b8; }
  .component-card:nth-child(3n) .component-card__visual { background: #dcecff; }
  .component-card__asset { width: 100%; height: 100%; display: grid; place-items: center; transform: translate3d(0, var(--parallax-y, 0), 0); }
  .component-card__asset img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(3px 5px 0 rgba(7,10,13,.28)); transition: scale .22s ease; }
  .component-card__copy { display: grid; align-content: center; min-height: 58px; padding: .65rem .75rem .7rem; }
  .component-card__copy h3 { margin: 0; font-size: .93rem; line-height: 1.02; }
  .component-card__copy p { margin: .2rem 0 0; color: var(--muted); font-size: .68rem; font-weight: 800; line-height: 1.15; }
  .component-card__placeholder { width: 78px; height: 78px; display: grid; place-items: center; border: 3px solid var(--ink); border-radius: 50%; background: white; box-shadow: 3px 4px 0 var(--ink); }
  .component-card__placeholder span { font-family: var(--font-display-family); font-size: 1.7rem; font-weight: 900; }
  @media (hover: hover) {
    .component-card:hover { transform: translateY(-4px); box-shadow: 6px 7px 0 var(--ink); }
    .component-card:hover img { scale: 1.045; }
  }
  @media (min-width: 700px) { .kit-components__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } .component-card__visual { aspect-ratio: 1.3 / 1; } }
  @media (min-width: 1180px) { .kit-components__grid { grid-template-columns: repeat(8, minmax(0, 1fr)); } .component-card__copy { min-height: 62px; } }
  @media (max-width: 520px) {
    .kit-components__grid { gap: .55rem; }
    .component-card { border-width: 2px; box-shadow: 2px 3px 0 var(--ink); }
    .component-card__visual { aspect-ratio: 1.55 / 1; padding: .42rem; border-bottom-width: 2px; }
    .component-card__copy { min-height: 48px; padding: .5rem .55rem .55rem; }
    .component-card__copy h3 { font-size: .78rem; }
    .component-card__copy p { font-size: .58rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Kit components",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Inside the box" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick a part. Build a project." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>The BREADBOX hardware lineup, packed into one compact kit.</p>" }
  ],
  "blocks": [{
    "type": "component",
    "name": "Component",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Custom image" },
      { "type": "select", "id": "asset", "label": "Built-in image", "options": [
        { "value": "component-arduino-uno.png", "label": "Arduino UNO" },
        { "value": "component-breadboard.png", "label": "Mini breadboard" },
        { "value": "component-oled.png", "label": "OLED display" },
        { "value": "component-joystick.png", "label": "Joystick" },
        { "value": "component-mpu6050.png", "label": "MPU6050" },
        { "value": "component-servo.png", "label": "SG90 servo" },
        { "value": "component-button.svg", "label": "Push button" },
        { "value": "component-buzzer.svg", "label": "Passive buzzer" },
        { "value": "none", "label": "Graphic placeholder" }
      ], "default": "component-arduino-uno.png" },
      { "type": "text", "id": "symbol", "label": "Placeholder symbol", "default": "+" },
      { "type": "text", "id": "title", "label": "Name", "default": "Arduino UNO R3" },
      { "type": "text", "id": "text", "label": "Short description", "default": "The brain of every build" },
      { "type": "range", "id": "parallax", "label": "Scroll movement", "min": -8, "max": 8, "step": 1, "default": 3 }
    ]
  }],
  "presets": [{
    "name": "Kit components",
    "blocks": [
      { "type": "component", "settings": { "asset": "component-arduino-uno.png", "title": "Arduino UNO R3", "text": "The brain of every build", "parallax": 3 } },
      { "type": "component", "settings": { "asset": "component-breadboard.png", "title": "Mini breadboard", "text": "Build without soldering", "parallax": -3 } },
      { "type": "component", "settings": { "asset": "component-oled.png", "title": "SSD1306 OLED", "text": "Crisp graphics and games", "parallax": 4 } },
      { "type": "component", "settings": { "asset": "component-joystick.png", "title": "Joystick module", "text": "Two-axis control", "parallax": -2 } },
      { "type": "component", "settings": { "asset": "component-mpu6050.png", "title": "MPU6050", "text": "Motion and tilt sensing", "parallax": 4 } },
      { "type": "component", "settings": { "asset": "component-servo.png", "title": "SG90 servo", "text": "Make projects move", "parallax": -4 } },
      { "type": "component", "settings": { "asset": "component-button.svg", "symbol": "●", "title": "Push buttons", "text": "Simple tactile input", "parallax": 2 } },
      { "type": "component", "settings": { "asset": "component-buzzer.svg", "symbol": "))", "title": "Passive buzzer", "text": "Sound and feedback", "parallax": -2 } }
    ]
  }]
}
{% endschema %}
