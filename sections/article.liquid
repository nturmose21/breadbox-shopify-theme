<article class="article-page section-shell">
  <header><p class="eyebrow">{{ article.published_at | date: '%B %d, %Y' }} · {{ article.author | escape }}</p><h1>{{ article.title | escape }}</h1></header>
  {% if article.image %}<div class="article-page__hero card">{{ article.image | image_url: width: 1800 | image_tag: widths: '700, 1100, 1500, 1800', sizes: '92vw', loading: 'eager', alt: article.image.alt | default: article.title }}</div>{% endif %}
  <div class="rte article-page__body">{{ article.content }}</div>
  {% if blog.comments_enabled? %}
    <section class="article-comments" id="comments"><h2>Comments</h2>{% for comment in article.comments %}<div class="card"><strong>{{ comment.author | escape }}</strong><p>{{ comment.content }}</p></div>{% endfor %}
      {% form 'new_comment', article %}<h2>Leave a comment</h2>{{ form.errors | default_errors }}<label for="CommentAuthor">Name</label><input id="CommentAuthor" type="text" name="comment[author]" required><label for="CommentEmail">Email</label><input id="CommentEmail" type="email" name="comment[email]" required><label for="CommentBody">Comment</label><textarea id="CommentBody" name="comment[body]" rows="6" required></textarea><button class="button button--yellow" type="submit">Post comment</button>{% endform %}
    </section>
  {% endif %}
</article>

{% stylesheet %}
  .article-page { max-width: 920px; }
  .article-page header { max-width: 780px; margin-bottom: 2rem; }
  .article-page__hero { overflow: hidden; margin-bottom: 2.5rem; }
  .article-page__hero img { width: 100%; }
  .article-page__body { max-width: 760px; margin: auto; font-size: 1.05rem; }
  .article-page__body :is(h2,h3) { margin-top: 2rem; }
  .article-comments { max-width: 760px; margin: 4rem auto 0; display: grid; gap: 1rem; }
  .article-comments .card { padding: 1rem; }
  .article-comments form { display: grid; gap: .6rem; margin-top: 2rem; }
{% endstylesheet %}
{% schema %}{ "name": "Main article", "settings": [] }{% endschema %}
