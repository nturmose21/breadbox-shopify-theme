<section class="cart-page section-shell">
  <div class="section-heading"><p class="eyebrow">Ready to build</p><h1>Your cart</h1></div>
  {% if cart.item_count == 0 %}
    <div class="empty-state"><h2>Your workbench is empty</h2><p>Pick a BREADBOX and start your first project.</p><a class="button button--yellow" href="{{ routes.all_products_collection_url }}">Shop the kits →</a></div>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post" class="cart-layout">
      <div class="cart-items">
        {% for item in cart.items %}
          <article class="cart-item card">
            <a class="cart-item__image" href="{{ item.url }}">{% if item.image %}{{ item.image | image_url: width: 360 | image_tag: widths: '180, 270, 360', sizes: '150px', loading: 'lazy', alt: item.image.alt | default: item.product.title }}{% endif %}</a>
            <div class="cart-item__content">
              <h2><a href="{{ item.url }}">{{ item.product.title | escape }}</a></h2>
              {% unless item.product.has_only_default_variant %}<p>{{ item.variant.title | escape }}</p>{% endunless %}
              {% for property in item.properties %}{% assign first_character = property.first | slice: 0 %}{% unless property.last == blank or first_character == '_' %}<p><strong>{{ property.first }}:</strong> {{ property.last }}</p>{% endunless %}{% endfor %}
              {% if item.line_level_discount_allocations.size > 0 %}<ul>{% for discount in item.line_level_discount_allocations %}<li>{{ discount.discount_application.title }} (-{{ discount.amount | money }})</li>{% endfor %}</ul>{% endif %}
              <a class="cart-item__remove" href="{{ item.url_to_remove }}">Remove</a>
            </div>
            <div class="cart-item__controls">
              <label for="Quantity-{{ item.index | plus: 1 }}">Quantity</label>
              <input id="Quantity-{{ item.index | plus: 1 }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              <div class="price">{% if item.original_line_price != item.final_line_price %}<s>{{ item.original_line_price | money }}</s>{% endif %}<span>{{ item.final_line_price | money }}</span></div>
            </div>
          </article>
        {% endfor %}
        <button class="button button--white" type="submit" name="update">Update cart</button>
      </div>
      <aside class="cart-summary card">
        <h2>Order summary</h2>
        {% if cart.cart_level_discount_applications.size > 0 %}{% for discount in cart.cart_level_discount_applications %}<div class="cart-summary__line"><span>{{ discount.title }}</span><strong>-{{ discount.total_allocated_amount | money }}</strong></div>{% endfor %}{% endif %}
        <div class="cart-summary__line cart-summary__total"><span>Subtotal</span><strong>{{ cart.total_price | money }}</strong></div>
        <p>Shipping and taxes are calculated at checkout.</p>
        <button class="button button--yellow button--full" type="submit" name="checkout">Secure checkout →</button>
        {% if additional_checkout_buttons %}<div class="additional-checkout-buttons">{{ content_for_additional_checkout_buttons }}</div>{% endif %}
        <div class="cart-summary__trust">✓ Secure payment<br>✓ Tracked shipping<br>✓ Helpful support</div>
      </aside>
    </form>
  {% endif %}
</section>

{% stylesheet %}
  .cart-layout { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(300px, .65fr); gap: 1.5rem; align-items: start; }
  .cart-items { display: grid; gap: 1rem; }
  .cart-item { display: grid; grid-template-columns: 150px 1fr 130px; gap: 1rem; padding: 1rem; }
  .cart-item__image { aspect-ratio: 1; overflow: hidden; border: 2px solid var(--ink); border-radius: 6px; background: white; }
  .cart-item__image img { width: 100%; height: 100%; object-fit: cover; }
  .cart-item h2 { font-size: 1.2rem; }
  .cart-item h2 a { text-decoration: none; }
  .cart-item__content p { margin: .25rem 0; font-size: .85rem; }
  .cart-item__remove { color: #a02d25; font-size: .8rem; font-weight: 900; }
  .cart-item__controls { display: grid; align-content: start; gap: .5rem; }
  .cart-item__controls label { font-size: .75rem; font-weight: 900; text-transform: uppercase; }
  .cart-summary { position: sticky; top: 1.5rem; padding: 1.4rem; background: var(--yellow); }
  .cart-summary__line { display: flex; justify-content: space-between; gap: 1rem; padding-block: .6rem; }
  .cart-summary__total { margin-top: .5rem; border-top: var(--line); font-size: 1.2rem; }
  .cart-summary > p { color: var(--muted); font-size: .8rem; }
  .cart-summary__trust { margin-top: 1rem; text-align: center; font-size: .75rem; font-weight: 900; line-height: 1.8; text-transform: uppercase; }
  @media (max-width: 860px) { .cart-layout { grid-template-columns: 1fr; } .cart-summary { position: static; } }
  @media (max-width: 600px) { .cart-item { grid-template-columns: 92px 1fr; } .cart-item__controls { grid-column: 1 / -1; grid-template-columns: 100px 1fr; align-items: end; } }
{% endstylesheet %}

{% schema %}{ "name": "Main cart", "settings": [] }{% endschema %}
