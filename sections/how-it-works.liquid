<section class="how-it-works section-shell--compact" data-motion-section>
  <div class="section-heading section-heading--center"><p class="eyebrow">{{ section.settings.eyebrow | escape }}</p><h2>{{ section.settings.heading | escape }}</h2></div>
  <div class="how-it-works__steps">
    {% for block in section.blocks %}
      <article class="build-step" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 110 }}ms;" {{ block.shopify_attributes }}>
        <div class="build-step__number">{{ forloop.index }}</div><h3>{{ block.settings.heading | escape }}</h3><p>{{ block.settings.text | escape }}</p>
      </article>
      {% unless forloop.last %}<div class="build-step__line" aria-hidden="true"><span>→</span></div>{% endunless %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .how-it-works .section-heading { margin-bottom: 1.4rem; }
  .how-it-works .section-heading h2 { letter-spacing: -.035em; }
  .how-it-works__steps { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 1rem; align-items: center; }
  .build-step { min-height: 150px; display: grid; align-content: center; justify-items: center; padding: 1.2rem; border: 1px solid rgba(7,10,13,.14); border-radius: 18px; background: rgba(255,253,246,.88); box-shadow: 0 18px 48px rgba(7,10,13,.08); text-align: center; }
  .build-step__number { width: 42px; height: 42px; display: grid; place-items: center; margin-bottom: .7rem; border-radius: 50%; background: var(--yellow); font-family: var(--font-display-ui); font-size: 1rem; font-weight: 900; box-shadow: 0 12px 24px rgba(7,10,13,.14); }
  .build-step:nth-of-type(3) .build-step__number { background: var(--teal); }
  .build-step h3 { margin-bottom: .28rem; font-size: 1.2rem; letter-spacing: -.015em; }
  .build-step p { margin: 0; color: var(--muted); font-size: .78rem; font-weight: 750; line-height: 1.28; }
  .build-step__line { width: clamp(24px, 4vw, 56px); height: 1px; background: rgba(7,10,13,.24); }
  .build-step__line span { display: block; margin-top: -18px; color: rgba(7,10,13,.42); text-align: center; font-size: 1.6rem; font-weight: 900; }
  @media (max-width: 720px) {
    .how-it-works__steps { grid-template-columns: 1fr; gap: .65rem; }
    .build-step { min-height: 0; grid-template-columns: 42px minmax(0, 1fr); justify-items: start; column-gap: .75rem; padding: .85rem; text-align: left; border-radius: 16px; }
    .build-step__number { grid-row: 1 / 3; width: 34px; height: 34px; margin: 0; font-size: .92rem; }
    .build-step h3 { margin-bottom: .12rem; font-size: .92rem; }
    .build-step p { font-size: .68rem; }
    .build-step__line { width: 1px; height: 18px; margin: -.35rem 0 -.35rem 21px; }
    .build-step__line span { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No guesswork" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open. Follow. Build." }
  ],
  "blocks": [{ "type": "step", "name": "Step", "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open the kit" },
    { "type": "text", "id": "text", "label": "Description", "default": "Everything starts in one compact box." }
  ] }],
  "presets": [{ "name": "How it works", "blocks": [
    { "type": "step", "settings": { "heading": "Open the kit", "text": "Everything starts in one compact box." } },
    { "type": "step", "settings": { "heading": "Follow the tutorials", "text": "Clear steps guide every wire and upload." } },
    { "type": "step", "settings": { "heading": "Build real projects", "text": "Play, learn, then make the code your own." } }
  ] }]
}
{% endschema %}
