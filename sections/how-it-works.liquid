<section class="how-it-works section-shell--compact" data-motion-section>
  <div class="section-heading section-heading--center"><p class="eyebrow">{{ section.settings.eyebrow | escape }}</p><h2>{{ section.settings.heading | escape }}</h2></div>
  <div class="how-it-works__steps">
    {% for block in section.blocks %}
      <article class="build-step" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 110 }}ms;" {{ block.shopify_attributes }}>
        <div class="build-step__number">{{ forloop.index }}</div><h3>{{ block.settings.heading | escape }}</h3><p>{{ block.settings.text | escape }}</p>
      </article>
      {% unless forloop.last %}<div class="build-step__line" aria-hidden="true"><span>→</span></div>{% endunless %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .how-it-works__steps { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 1rem; align-items: center; }
  .build-step { min-height: 190px; display: grid; align-content: start; justify-items: center; padding: 1.3rem; border: 3px solid var(--ink); border-radius: var(--radius); background: var(--paper-bright); box-shadow: 3px 4px 0 var(--ink); text-align: center; }
  .build-step__number { width: 46px; height: 46px; display: grid; place-items: center; margin-bottom: .75rem; border: 3px solid var(--ink); border-radius: 50%; background: var(--yellow); font-family: var(--font-display-family); font-size: 1.25rem; font-weight: 900; }
  .build-step:nth-of-type(3) .build-step__number { background: var(--teal); }
  .build-step h3 { font-size: 1.2rem; }
  .build-step p { margin: 0; color: var(--muted); font-size: .86rem; }
  .build-step__line { width: clamp(36px, 5vw, 72px); height: 3px; background: var(--ink); }
  .build-step__line span { display: block; margin-top: -18px; text-align: center; font-size: 1.6rem; font-weight: 900; }
  @media (max-width: 720px) { .how-it-works__steps { grid-template-columns: 1fr; } .build-step { min-height: 0; grid-template-columns: 52px 1fr; justify-items: start; text-align: left; column-gap: .8rem; } .build-step__number { grid-row: 1 / 3; margin: 0; } .build-step__line { width: 3px; height: 28px; margin: -.25rem 0 -.25rem 24px; } .build-step__line span { display: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No guesswork" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open. Follow. Build." }
  ],
  "blocks": [{ "type": "step", "name": "Step", "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open the kit" },
    { "type": "text", "id": "text", "label": "Description", "default": "Everything starts in one compact box." }
  ] }],
  "presets": [{ "name": "How it works", "blocks": [
    { "type": "step", "settings": { "heading": "Open the kit", "text": "Everything starts in one compact box." } },
    { "type": "step", "settings": { "heading": "Follow the tutorials", "text": "Clear steps guide every wire and upload." } },
    { "type": "step", "settings": { "heading": "Build real projects", "text": "Play, learn, then make the code your own." } }
  ] }]
}
{% endschema %}
