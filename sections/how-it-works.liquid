<section class="how-it-works section-shell--compact" data-motion-section>
  <div class="section-heading"><p class="eyebrow">{{ section.settings.eyebrow | escape }}</p><h2>{{ section.settings.heading | escape }}</h2></div>
  <div class="how-it-works__steps">
    {% for block in section.blocks %}
      <article class="build-step" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 110 }}ms;" {{ block.shopify_attributes }}>
        <div class="build-step__number">{{ forloop.index }}</div><h3>{{ block.settings.heading | escape }}</h3><p>{{ block.settings.text | escape }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .how-it-works .section-heading { max-width: 760px; margin-bottom: 1.4rem; }
  .how-it-works .section-heading h2 { letter-spacing: 0; }
  .how-it-works__steps { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); border: 2px solid var(--ink); background: white; }
  .build-step { min-height: 190px; display: grid; align-content: start; padding: 1.2rem; border-right: 2px solid var(--ink); background: white; text-align: left; }
  .build-step:last-child { border-right: 0; }
  .build-step__number { width: 38px; height: 38px; display: grid; place-items: center; margin-bottom: 2rem; border: 2px solid var(--ink); border-radius: 3px; background: var(--yellow); font-family: var(--font-display-ui); font-size: .9rem; font-weight: 900; }
  .build-step h3 { margin-bottom: .35rem; font-size: 1.35rem; letter-spacing: 0; }
  .build-step p { max-width: 28ch; margin: 0; color: var(--muted); font-size: .82rem; font-weight: 700; line-height: 1.35; }
  @media (max-width: 720px) {
    .how-it-works__steps { grid-template-columns: 1fr; }
    .build-step { min-height: 0; grid-template-columns: 38px minmax(0, 1fr); column-gap: .8rem; padding: .9rem; border-right: 0; border-bottom: 2px solid var(--ink); }
    .build-step:last-child { border-bottom: 0; }
    .build-step__number { grid-row: 1 / 3; width: 34px; height: 34px; margin: 0; }
    .build-step h3 { margin-bottom: .15rem; font-size: 1.05rem; }
    .build-step p { font-size: .74rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No guesswork" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open. Follow. Build." }
  ],
  "blocks": [{ "type": "step", "name": "Step", "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open the kit" },
    { "type": "text", "id": "text", "label": "Description", "default": "Everything starts in one compact box." }
  ] }],
  "presets": [{ "name": "How it works", "blocks": [
    { "type": "step", "settings": { "heading": "Open the kit", "text": "Everything starts in one compact box." } },
    { "type": "step", "settings": { "heading": "Follow the tutorials", "text": "Clear steps guide every wire and upload." } },
    { "type": "step", "settings": { "heading": "Build real projects", "text": "Play, learn, then make the code your own." } }
  ] }]
}
{% endschema %}
