<section class="how-it-works full-width" data-motion-section>
  <div class="how-it-works__inner section-shell--compact">
    <div class="section-heading"><p class="eyebrow">{{ section.settings.eyebrow | escape }}</p><h2>{{ section.settings.heading | escape }}</h2></div>
    <div class="how-it-works__steps">
      {% for block in section.blocks %}
        <article class="build-step" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 110 }}ms;" {{ block.shopify_attributes }}>
          <div class="build-step__number">{{ forloop.index }}</div><h3>{{ block.settings.heading | escape }}</h3><p>{{ block.settings.text | escape }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .how-it-works { background: #f5f5f7; }
  .how-it-works__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; }
  .how-it-works .section-heading { max-width: 760px; margin: 0 auto clamp(2rem, 4vw, 3.4rem); text-align: center; }
  .how-it-works .section-heading h2 { letter-spacing: 0; }
  .how-it-works__steps { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(1.5rem, 4vw, 4rem); }
  .build-step { min-height: 190px; display: grid; align-content: start; justify-items: center; padding: 1rem; text-align: center; }
  .build-step__number { width: 46px; height: 46px; display: grid; place-items: center; margin-bottom: 1.5rem; border-radius: 50%; background: #e2edf7; color: var(--blue); font-family: var(--font-display-ui); font-size: .95rem; font-weight: 800; }
  .build-step h3 { margin-bottom: .45rem; font-size: 1.32rem; letter-spacing: 0; }
  .build-step p { max-width: 28ch; margin: 0; color: var(--muted); font-size: .84rem; font-weight: 600; line-height: 1.45; }
  @media (max-width: 720px) {
    .how-it-works__steps { grid-template-columns: 1fr; }
    .build-step { min-height: 0; grid-template-columns: 46px minmax(0, 1fr); justify-items: start; column-gap: .9rem; padding: .65rem 0; text-align: left; }
    .build-step__number { grid-row: 1 / 3; width: 42px; height: 42px; margin: 0; }
    .build-step h3 { margin-bottom: .2rem; font-size: 1.08rem; }
    .build-step p { font-size: .78rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No guesswork" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open. Follow. Build." }
  ],
  "blocks": [{ "type": "step", "name": "Step", "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open the kit" },
    { "type": "text", "id": "text", "label": "Description", "default": "Everything starts in one compact box." }
  ] }],
  "presets": [{ "name": "How it works", "blocks": [
    { "type": "step", "settings": { "heading": "Open the kit", "text": "Everything starts in one compact box." } },
    { "type": "step", "settings": { "heading": "Follow the tutorials", "text": "Clear steps guide every wire and upload." } },
    { "type": "step", "settings": { "heading": "Build real projects", "text": "Play, learn, then make the code your own." } }
  ] }]
}
{% endschema %}
