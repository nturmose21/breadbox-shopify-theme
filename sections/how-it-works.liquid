<section class="how-it-works full-width" id="process" data-motion-section>
  <div class="how-it-works__inner section-shell">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      <div class="rte">{{ section.settings.text }}</div>
    </div>

    <div class="how-it-works__steps">
      {% for block in section.blocks %}
        <article class="build-step" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 90 }}ms;" {{ block.shopify_attributes }}>
          <div class="build-step__visual build-step__visual--{{ block.settings.visual }}" aria-hidden="true">
            {% case block.settings.visual %}
              {% when 'build' %}
                <span class="build-step__part build-step__part--board"><img src="{{ 'component-breadboard.png' | asset_url }}" alt="" width="500" height="500" loading="lazy"></span>
                <span class="build-step__part build-step__part--screen"><img src="{{ 'component-oled.png' | asset_url }}" alt="" width="1200" height="1200" loading="lazy"></span>
                <span class="build-step__part build-step__part--button"><img src="{{ 'component-button.png' | asset_url }}" alt="" width="300" height="300" loading="lazy"></span>
              {% when 'flash' %}
                <div class="build-step__browser">
                  <span class="build-step__browser-bar"><i></i><i></i><i></i><b>uploader.breadbox.fun</b></span>
                  <span class="build-step__port">Arduino UNO <b>connected</b></span>
                  <span class="build-step__progress"><i></i></span>
                  <strong>FLASH COMPLETE</strong>
                </div>
              {% else %}
                <pre class="build-step__code"><span>01</span> <b>void</b> loop() {
<span>02</span>   pet.hunger++;
<span>03</span>   <em>drawPet</em>();
<span>04</span> }</pre>
            {% endcase %}
          </div>
          <div class="build-step__copy">
            <span class="build-step__number">0{{ forloop.index }}</span>
            <h3>{{ block.settings.heading | escape }}</h3>
            <p>{{ block.settings.text | escape }}</p>
            {% if block.settings.note != blank %}<small>{{ block.settings.note | escape }}</small>{% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .how-it-works { background: var(--ink); color: white; }
  .how-it-works__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; }
  .how-it-works .section-heading { max-width: 760px; margin-bottom: clamp(2rem, 4vw, 3.25rem); }
  .how-it-works .section-heading .eyebrow { color: var(--teal); }
  .how-it-works .section-heading .rte { max-width: 48ch; color: #b9bec4; }
  .how-it-works__steps { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(.8rem, 1.6vw, 1.3rem); }
  .build-step { min-width: 0; overflow: hidden; border: 1px solid #41464d; border-radius: var(--radius-lg); background: var(--night-soft); }
  .build-step__visual { height: clamp(210px, 20vw, 285px); position: relative; overflow: hidden; border-bottom: 1px solid #41464d; background: #1c2025; }
  .build-step__copy { min-height: 190px; display: grid; align-content: start; padding: 1.2rem; }
  .build-step__number { margin-bottom: 1.2rem; color: var(--teal); font-family: var(--font-mono-ui); font-size: .64rem; font-weight: 700; }
  .build-step h3 { margin-bottom: .5rem; font-size: clamp(1.35rem, 2.1vw, 1.8rem); }
  .build-step p { max-width: 31ch; margin: 0; color: #c4c8cd; font-size: .88rem; line-height: 1.5; }
  .build-step small { margin-top: 1rem; color: var(--teal); font-family: var(--font-mono-ui); font-size: .58rem; font-weight: 700; text-transform: uppercase; }
  .build-step__part { position: absolute; display: block; filter: drop-shadow(10px 12px 10px rgba(0,0,0,.4)); }
  .build-step__part img { width: 100%; height: 100%; object-fit: contain; }
  .build-step__part--board { width: 62%; left: 17%; bottom: -8%; transform: rotate(-4deg); }
  .build-step__part--screen { width: 34%; right: 8%; top: 6%; transform: rotate(7deg); }
  .build-step__part--button { width: 19%; left: 7%; top: 12%; transform: rotate(-9deg); }
  .build-step__browser { width: calc(100% - 2rem); max-width: 340px; position: absolute; inset: 50% auto auto 50%; transform: translate(-50%, -50%); overflow: hidden; border: 1px solid #59616a; border-radius: var(--radius); background: #101317; box-shadow: 0 18px 36px rgba(0,0,0,.35); font-family: var(--font-mono-ui); }
  .build-step__browser-bar { min-height: 30px; display: flex; align-items: center; gap: .3rem; padding: .45rem .55rem; border-bottom: 1px solid #41464d; color: #8e969f; font-size: .5rem; }
  .build-step__browser-bar i { width: 7px; height: 7px; border-radius: 50%; background: #59616a; }
  .build-step__browser-bar i:first-child { background: var(--orange); }
  .build-step__browser-bar i:nth-child(2) { background: var(--teal); }
  .build-step__browser-bar b { margin-left: auto; font-weight: 500; }
  .build-step__port { display: flex; justify-content: space-between; gap: .5rem; margin: .8rem; border: 1px solid #41464d; border-radius: 3px; padding: .55rem; color: #c7ccd1; font-size: .58rem; }
  .build-step__port b { color: var(--teal); }
  .build-step__progress { height: 7px; display: block; margin: .8rem; overflow: hidden; border-radius: 2px; background: #31363c; }
  .build-step__progress i { width: 100%; height: 100%; display: block; background: var(--blue); }
  .build-step__browser > strong { display: block; padding: 0 .8rem .85rem; color: var(--teal); font-size: .6rem; }
  .build-step__code { position: absolute; inset: 50% auto auto 50%; transform: translate(-50%, -50%); width: calc(100% - 2rem); max-width: 330px; margin: 0; border-left: 3px solid var(--blue); padding: 1rem; background: #101317; color: #d6d9dd; font-family: var(--font-mono-ui); font-size: clamp(.58rem, 1vw, .72rem); line-height: 1.9; box-shadow: 0 18px 36px rgba(0,0,0,.3); }
  .build-step__code span { color: #69717a; }
  .build-step__code b { color: var(--blue); }
  .build-step__code em { color: var(--teal); font-style: normal; }
  @media (max-width: 820px) {
    .how-it-works__steps { grid-template-columns: 1fr; }
    .build-step { display: grid; grid-template-columns: minmax(240px, .85fr) minmax(0, 1fr); }
    .build-step__visual { height: 260px; border-right: 1px solid #41464d; border-bottom: 0; }
    .build-step__copy { min-height: 260px; align-content: center; }
  }
  @media (max-width: 580px) {
    .build-step { display: block; }
    .build-step__visual { height: 210px; border-right: 0; border-bottom: 1px solid #41464d; }
    .build-step__copy { min-height: 0; padding: 1rem; }
    .build-step__number { margin-bottom: .8rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hardware meets software" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Build it. Flash it. Make it yours." },
    { "type": "richtext", "id": "text", "label": "Introduction", "default": "<p>Start with a working project, then open the code and see how every part behaves.</p>" }
  ],
  "blocks": [{
    "type": "step",
    "name": "Step",
    "settings": [
      { "type": "select", "id": "visual", "label": "Visual", "options": [{"value":"build","label":"Build hardware"},{"value":"flash","label":"Browser uploader"},{"value":"mod","label":"Edit code"}], "default": "build" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Build" },
      { "type": "text", "id": "text", "label": "Description", "default": "Follow the wiring guide and snap the project together on the mini breadboard." },
      { "type": "text", "id": "note", "label": "Technical note", "default": "Real parts / real circuits" }
    ]
  }],
  "presets": [{
    "name": "How it works",
    "blocks": [
      { "type": "step", "settings": { "visual": "build", "heading": "Build", "text": "Follow the wiring guide and snap the project together on the mini breadboard.", "note": "Real parts / real circuits" } },
      { "type": "step", "settings": { "visual": "flash", "heading": "Flash", "text": "Choose a project and upload it straight from your browser. No IDE installation required.", "note": "USB in / instant upload" } },
      { "type": "step", "settings": { "visual": "mod", "heading": "Mod", "text": "Open the raw C++ source, change the behavior, and learn by making it your own.", "note": "Full source code included" } }
    ]
  }]
}
{% endschema %}
