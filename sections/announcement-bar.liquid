{% if section.settings.text != blank %}
  <div class="announcement full-width" style="--announcement-bg: {{ section.settings.background }}; --announcement-text: {{ section.settings.text_color }};">
    {% if section.settings.link != blank %}<a href="{{ section.settings.link }}">{% endif %}
      <span>{{ section.settings.text | escape }}</span>
      {% if section.settings.link_label != blank %}<strong>{{ section.settings.link_label | escape }} →</strong>{% endif %}
    {% if section.settings.link != blank %}</a>{% endif %}
  </div>
{% endif %}

{% stylesheet %}
  .announcement { min-height: 38px; display: flex; align-items: center; justify-content: center; padding: .45rem 1rem; background: var(--announcement-bg); color: var(--announcement-text); border-bottom: 2px solid var(--ink); font-size: .82rem; font-weight: 900; text-transform: uppercase; text-align: center; }
  .announcement a { display: flex; flex-wrap: wrap; justify-content: center; gap: .35rem 1rem; color: inherit; text-decoration: none; }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Free tracked shipping on launch orders" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop the kit" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffbf18" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#070a0d" }
  ]
}
{% endschema %}
