{% liquid
  assign featured_product = section.settings.product
  if featured_product == blank
    assign featured_product = collections.all.products.first
  endif
  assign current_variant = featured_product.selected_or_first_available_variant
%}

<section class="hero-product full-width" data-motion-section>
  <div class="hero-product__blueprint" aria-hidden="true"></div>
  <div class="hero-product__scene" aria-label="BREADBOX kit components">
    <div class="hero-product__platform" aria-hidden="true"></div>
    {% for block in section.blocks %}
      {% liquid
        assign component_asset = block.settings.asset
        assign component_alt = block.settings.label | default: 'Arduino kit component'
        assign component_loading = 'lazy'
        if forloop.index <= 2
          assign component_loading = 'eager'
        endif
      %}
      <div
        class="hero-part hero-part--{{ block.settings.position }}"
        style="--part-delay: {{ forloop.index0 | times: 0.12 }}s; --float-range: {{ block.settings.float_range | divided_by: 2 }}px; --float-negative: -{{ block.settings.float_range | divided_by: 2 }}px;"
        data-parallax="{{ block.settings.parallax }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 900 | image_tag: widths: '240, 360, 540, 720, 900', sizes: '(min-width: 900px) 34vw, 45vw', loading: component_loading, alt: component_alt }}
        {% else %}
          <img src="{{ component_asset | asset_url }}" alt="{{ component_alt | escape }}" width="700" height="700" loading="{{ component_loading }}">
        {% endif %}
      </div>
    {% endfor %}
    <div class="hero-product__spark hero-product__spark--one" aria-hidden="true">+</div>
    <div class="hero-product__spark hero-product__spark--two" aria-hidden="true">✦</div>
    <div class="hero-product__spark hero-product__spark--three" aria-hidden="true">⚡</div>
  </div>

  <div class="hero-product__content" data-reveal="left">
    <p class="hero-product__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h1>{{ section.settings.heading | escape }}</h1>
    <div class="hero-product__copy rte">{{ section.settings.text }}</div>
    {% if featured_product != blank %}
      <div class="hero-product__buy" data-product-root>
        {% render 'price', product: featured_product %}
        {% form 'product', featured_product, data-product-form: '' %}
          {% if featured_product.has_only_default_variant %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% else %}
            <label class="visually-hidden" for="HeroVariant-{{ section.id }}">Choose your kit</label>
            <select id="HeroVariant-{{ section.id }}" name="id">
              {% for variant in featured_product.variants %}
                <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" data-available="{{ variant.available }}" {% if variant == current_variant %}selected{% endif %}>{{ variant.title }} — {{ variant.price | money }}</option>
              {% endfor %}
            </select>
          {% endif %}
          <button class="button button--yellow" type="submit" name="add" {% unless current_variant.available %}disabled{% endunless %}><span>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span> →</button>
        {% endform %}
        <a class="hero-product__details" href="{{ featured_product.url }}">Explore the kit</a>
      </div>
    {% else %}
      <a class="button button--yellow" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label | escape }} →</a>
    {% endif %}
    <ul class="hero-product__promises" role="list">
      <li>Beginner ready</li><li>10+ builds</li><li>Reusable hardware</li>
    </ul>
  </div>
</section>

{% stylesheet %}
  .hero-product {
    min-height: clamp(660px, 86svh, 860px);
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(330px, .78fr);
    gap: clamp(2rem, 5vw, 6rem);
    align-items: center;
    overflow: clip;
    padding: clamp(2rem, 5vw, 5rem) max(var(--page-margin), calc((100% - var(--page-width)) / 2));
    border-bottom: 1px solid rgba(255,255,255,.16);
    background:
      radial-gradient(circle at 28% 50%, rgba(34,200,194,.28), transparent 34%),
      radial-gradient(circle at 75% 10%, rgba(255,191,24,.2), transparent 28%),
      linear-gradient(135deg, #071018 0%, #082b47 52%, #071018 100%);
    color: white;
    isolation: isolate;
  }
  .hero-product::after {
    content: "";
    position: absolute;
    inset: auto -10% -22% -10%;
    height: 42%;
    background: linear-gradient(to top, rgba(255,246,220,.98), rgba(255,246,220,0));
    pointer-events: none;
    z-index: 1;
  }
  .hero-product__blueprint { position: absolute; inset: 0; opacity: .2; background-image: linear-gradient(rgba(255,255,255,.18) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.18) 1px, transparent 1px); background-size: 46px 46px; mask-image: radial-gradient(circle at 44% 48%, black, transparent 66%); }
  .hero-product__content { position: relative; z-index: 5; min-width: 0; max-width: 560px; justify-self: start; }
  .hero-product__eyebrow { width: fit-content; margin-bottom: 1rem; border: 1px solid rgba(255,255,255,.28); border-radius: 999px; padding: .48rem .78rem; background: rgba(34,200,194,.16); color: #9ff4ef; box-shadow: inset 0 0 0 1px rgba(34,200,194,.24); font-size: .7rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
  .hero-product h1 { max-width: 7.8ch; margin-bottom: 1rem; font-size: clamp(4rem, 8.4vw, 9rem); letter-spacing: -.035em; text-shadow: 0 20px 50px rgba(0,0,0,.42); }
  .hero-product__copy { max-width: 32ch; color: rgba(255,255,255,.82); font-size: clamp(1rem, 1.4vw, 1.2rem); font-weight: 750; line-height: 1.42; }
  .hero-product__buy { display: flex; flex-wrap: wrap; align-items: center; gap: .8rem 1rem; margin-top: 1.6rem; }
  .hero-product__buy .price { color: white; font-size: 2.05rem; text-shadow: 0 12px 28px rgba(0,0,0,.28); }
  .hero-product__buy form { display: flex; align-items: center; gap: .65rem; }
  .hero-product__buy select { width: auto; min-width: 150px; background: rgba(255,255,255,.92); }
  .hero-product__details { color: rgba(255,255,255,.76); font-size: .82rem; font-weight: 850; text-decoration-color: rgba(34,200,194,.8); }
  .hero-product__promises { display: flex; flex-wrap: wrap; gap: .55rem; margin: 1.45rem 0 0; padding: 0; list-style: none; }
  .hero-product__promises li { border: 1px solid rgba(255,255,255,.2); border-radius: 999px; padding: .42rem .7rem; background: rgba(255,255,255,.07); color: rgba(255,255,255,.8); font-size: .68rem; font-weight: 850; text-transform: uppercase; }

  .hero-product__scene {
    position: relative;
    z-index: 4;
    min-width: 0;
    width: min(100%, 820px);
    justify-self: center;
    aspect-ratio: 1.2 / 1;
    border: 1px solid rgba(255,255,255,.28);
    border-radius: 28px;
    background:
      radial-gradient(circle at 55% 55%, rgba(255,191,24,.28), transparent 24%),
      linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px),
      linear-gradient(145deg, rgba(255,255,255,.12), rgba(255,255,255,.035));
    background-size: auto, 34px 34px, 34px 34px, auto;
    box-shadow: 0 40px 120px rgba(0,0,0,.48), inset 0 1px 0 rgba(255,255,255,.3);
    overflow: hidden;
    pointer-events: none;
    transform: perspective(1100px) rotateX(4deg) rotateY(-5deg);
    transform-style: preserve-3d;
  }
  .hero-product__scene::before {
    content: "BREADBOX / UNO KIT";
    position: absolute;
    left: 1.1rem;
    top: 1rem;
    z-index: 7;
    color: rgba(255,255,255,.58);
    font-size: .65rem;
    font-weight: 900;
    letter-spacing: .16em;
  }
  .hero-product__platform { position: absolute; left: 13%; right: 13%; bottom: 10%; height: 18%; border-radius: 999px; background: linear-gradient(90deg, var(--yellow), #ffdf73); box-shadow: 0 22px 56px rgba(0,0,0,.35); transform: translateZ(18px) skewX(-7deg); }
  .hero-part { position: absolute; z-index: 3; filter: drop-shadow(0 16px 24px rgba(0,0,0,.42)); transform: translate3d(0, var(--parallax-y, 0), 0); }
  .hero-part img { width: 100%; height: 100%; object-fit: contain; animation: hero-float 7.5s cubic-bezier(.45,0,.2,1) infinite alternate; animation-delay: var(--part-delay); }
  .hero-part--uno { right: 12%; bottom: 16%; width: 36%; height: 32%; rotate: -4deg; z-index: 6; }
  .hero-part--breadboard { left: 8%; top: 14%; width: 24%; height: 20%; rotate: -2deg; z-index: 3; opacity: .9; }
  .hero-part--oled { right: 9%; top: 12%; width: 17%; height: 17%; rotate: 3deg; z-index: 5; }
  .hero-part--joystick { left: 10%; bottom: 12%; width: 20%; height: 21%; rotate: 2deg; z-index: 6; }
  .hero-part--sensor { right: 8%; bottom: 40%; width: 11%; height: 13%; rotate: 5deg; z-index: 7; }
  .hero-part--servo { left: 41%; top: 8%; width: 15%; height: 14%; rotate: -3deg; z-index: 5; }
  .hero-product__spark { position: absolute; z-index: 8; display: grid; place-items: center; width: clamp(2rem, 4vw, 3.1rem); aspect-ratio: 1; border: 1px solid rgba(255,255,255,.34); border-radius: 50%; background: rgba(255,255,255,.08); color: var(--yellow); font-family: var(--font-display-ui); font-size: clamp(1.1rem, 2vw, 1.7rem); font-weight: 900; backdrop-filter: blur(10px); }
  .hero-product__spark--one { left: 48%; top: 48%; }
  .hero-product__spark--two { right: 8%; bottom: 10%; }
  .hero-product__spark--three { left: 26%; bottom: 9%; color: var(--teal); }
  @keyframes hero-float { from { transform: translate3d(0, var(--float-negative), 18px); } to { transform: translate3d(0, var(--float-range), 34px); } }

  @media (max-width: 760px) {
    .hero-product { min-height: 0; grid-template-columns: 1fr; gap: 1.5rem; padding-block: 1.6rem 3rem; }
    .hero-product__scene { order: 1; width: min(720px, 100%); aspect-ratio: 1.7 / 1; transform: perspective(1000px) rotateX(3deg); }
    .hero-product__content { order: 2; max-width: 720px; }
    .hero-product h1 { max-width: 9ch; font-size: clamp(4rem, 12vw, 6rem); }
    .hero-product__buy form { flex-wrap: wrap; }
  }
  @media (max-width: 680px) {
    .hero-product { padding-block: 1rem 2.4rem; }
    .hero-product__scene { aspect-ratio: 1.55 / 1; border-radius: 18px; }
    .hero-product__scene::before { left: .85rem; top: .75rem; font-size: .52rem; }
    .hero-product__eyebrow { margin-bottom: .75rem; font-size: .62rem; }
    .hero-product h1 { max-width: 8ch; margin-bottom: .65rem; font-size: clamp(3rem, 15vw, 4.2rem); }
    .hero-product__copy { max-width: 30ch; font-size: .92rem; line-height: 1.42; }
    .hero-product__buy { margin-top: 1rem; gap: .55rem; }
    .hero-product__buy .price { font-size: 1.5rem; }
    .hero-product__buy, .hero-product__buy form { align-items: stretch; flex-direction: column; width: 100%; }
    .hero-product__buy select, .hero-product__buy .button { width: 100%; }
    .hero-product__buy .button { min-height: 48px; }
    .hero-product__details { text-align: center; }
    .hero-product__promises { gap: .35rem; margin-top: .85rem; }
    .hero-product__promises li { padding: .32rem .52rem; font-size: .56rem; }
    .hero-product__spark--one { display: none; }
    .hero-part { filter: drop-shadow(0 10px 14px rgba(0,0,0,.4)); }
    .hero-part--sensor, .hero-part--servo { display: none; }
    .hero-part--uno { right: 7%; bottom: 17%; width: 42%; height: 37%; }
    .hero-part--breadboard { left: 7%; top: 14%; width: 24%; height: 22%; }
    .hero-part--oled { right: 7%; top: 14%; width: 18%; height: 21%; }
    .hero-part--joystick { left: 8%; bottom: 14%; width: 23%; height: 27%; }
  }
  @media (max-width: 380px) {
    .hero-product h1 { font-size: 2.9rem; }
    .hero-product__promises li { padding-inline: .48rem; font-size: .58rem; }
  }
  @media (hover: none) { .hero-part img { animation-duration: 7s; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Product hero",
  "settings": [
    { "type": "product", "id": "product", "label": "Featured product" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Arduino starter kit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Arduino, boxed." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Real parts. Guided builds. Zero guesswork.</p>" },
    { "type": "text", "id": "button_label", "label": "Fallback button label", "default": "Shop BREADBOX" },
    { "type": "url", "id": "button_link", "label": "Fallback button link" }
  ],
  "blocks": [
    {
      "type": "component",
      "name": "Floating component",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Custom component image" },
        { "type": "select", "id": "asset", "label": "Built-in component", "options": [
          { "value": "component-arduino-uno.png", "label": "Arduino UNO" },
          { "value": "component-breadboard.png", "label": "Mini breadboard" },
          { "value": "component-oled.png", "label": "OLED display" },
          { "value": "component-joystick.png", "label": "Joystick" },
          { "value": "component-mpu6050.png", "label": "MPU6050" },
          { "value": "component-servo.png", "label": "SG90 servo" },
          { "value": "component-button.svg", "label": "Push button" },
          { "value": "component-buzzer.svg", "label": "Passive buzzer" }
        ], "default": "component-arduino-uno.png" },
        { "type": "text", "id": "label", "label": "Image alt text", "default": "Arduino component" },
        { "type": "select", "id": "position", "label": "Position", "options": [
          { "value": "uno", "label": "Main / lower right" },
          { "value": "breadboard", "label": "Upper right" },
          { "value": "oled", "label": "Upper left" },
          { "value": "joystick", "label": "Lower left" },
          { "value": "sensor", "label": "Middle right" },
          { "value": "servo", "label": "Top middle" }
        ], "default": "uno" },
        { "type": "range", "id": "float_range", "label": "Float distance", "min": 3, "max": 18, "step": 1, "unit": "px", "default": 8 },
        { "type": "range", "id": "parallax", "label": "Scroll movement", "min": -12, "max": 12, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [{
    "name": "Product hero",
    "blocks": [
      { "type": "component", "settings": { "asset": "component-arduino-uno.png", "label": "Arduino UNO R3", "position": "uno", "float_range": 7, "parallax": 4 } },
      { "type": "component", "settings": { "asset": "component-breadboard.png", "label": "170 point mini breadboard", "position": "breadboard", "float_range": 9, "parallax": -5 } },
      { "type": "component", "settings": { "asset": "component-oled.png", "label": "SSD1306 OLED display", "position": "oled", "float_range": 11, "parallax": 7 } },
      { "type": "component", "settings": { "asset": "component-joystick.png", "label": "Joystick module", "position": "joystick", "float_range": 6, "parallax": -4 } },
      { "type": "component", "settings": { "asset": "component-mpu6050.png", "label": "MPU6050 motion sensor", "position": "sensor", "float_range": 10, "parallax": 8 } },
      { "type": "component", "settings": { "asset": "component-servo.png", "label": "SG90 servo", "position": "servo", "float_range": 8, "parallax": -6 } }
    ]
  }]
}
{% endschema %}
