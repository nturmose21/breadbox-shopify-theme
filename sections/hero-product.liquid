{% liquid
  assign featured_product = section.settings.product
  if featured_product == blank
    assign featured_product = collections.all.products.first
  endif
  assign current_variant = featured_product.selected_or_first_available_variant
%}

<section class="hero-product full-width" data-motion-section>
  <div class="hero-product__blueprint" aria-hidden="true"></div>
  <div class="hero-product__scene" aria-label="BREADBOX kit components">
    <div class="hero-product__platform" aria-hidden="true"></div>
    {% for block in section.blocks %}
      {% liquid
        assign component_asset = block.settings.asset
        assign component_alt = block.settings.label | default: 'Arduino kit component'
        assign component_loading = 'lazy'
        if forloop.index <= 2
          assign component_loading = 'eager'
        endif
      %}
      <div
        class="hero-part hero-part--{{ block.settings.position }}"
        style="--part-delay: {{ forloop.index0 | times: 0.12 }}s; --float-range: {{ block.settings.float_range }}px; --float-negative: -{{ block.settings.float_range }}px;"
        data-parallax="{{ block.settings.parallax }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 900 | image_tag: widths: '240, 360, 540, 720, 900', sizes: '(min-width: 900px) 34vw, 45vw', loading: component_loading, alt: component_alt }}
        {% else %}
          <img src="{{ component_asset | asset_url }}" alt="{{ component_alt | escape }}" width="700" height="700" loading="{{ component_loading }}">
        {% endif %}
      </div>
    {% endfor %}
    <div class="hero-product__spark hero-product__spark--one" aria-hidden="true">+</div>
    <div class="hero-product__spark hero-product__spark--two" aria-hidden="true">✦</div>
    <div class="hero-product__spark hero-product__spark--three" aria-hidden="true">⚡</div>
  </div>

  <div class="hero-product__content" data-reveal="left">
    <p class="hero-product__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h1>{{ section.settings.heading | escape }}</h1>
    <div class="hero-product__copy rte">{{ section.settings.text }}</div>
    {% if featured_product != blank %}
      <div class="hero-product__buy" data-product-root>
        {% render 'price', product: featured_product %}
        {% form 'product', featured_product, data-product-form: '' %}
          {% if featured_product.has_only_default_variant %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% else %}
            <label class="visually-hidden" for="HeroVariant-{{ section.id }}">Choose your kit</label>
            <select id="HeroVariant-{{ section.id }}" name="id">
              {% for variant in featured_product.variants %}
                <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" data-available="{{ variant.available }}" {% if variant == current_variant %}selected{% endif %}>{{ variant.title }} — {{ variant.price | money }}</option>
              {% endfor %}
            </select>
          {% endif %}
          <button class="button button--yellow" type="submit" name="add" {% unless current_variant.available %}disabled{% endunless %}><span>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span> →</button>
        {% endform %}
        <a class="hero-product__details" href="{{ featured_product.url }}">Explore the kit</a>
      </div>
    {% else %}
      <a class="button button--yellow" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label | escape }} →</a>
    {% endif %}
    <ul class="hero-product__promises" role="list">
      <li>Beginner ready</li><li>10+ builds</li><li>Reusable hardware</li>
    </ul>
  </div>
</section>

{% stylesheet %}
  .hero-product {
    min-height: clamp(660px, 80svh, 780px);
    position: relative;
    display: block;
    align-items: center;
    overflow: clip;
    padding-inline: max(var(--page-margin), calc((100% - var(--page-width)) / 2));
    border-bottom: 4px solid var(--ink);
    background: var(--blue);
    color: white;
    isolation: isolate;
  }
  .hero-product__blueprint { position: absolute; inset: 0; opacity: .2; background-image: linear-gradient(rgba(255,255,255,.45) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.45) 1px, transparent 1px); background-size: 36px 36px; mask-image: linear-gradient(to right, transparent 4%, black 45%); }
  .hero-product__content { position: relative; z-index: 5; width: min(600px, 47%); padding-block: clamp(4.75rem, 7vw, 6rem); }
  .hero-product__eyebrow { width: fit-content; margin-bottom: 1rem; border: 2px solid var(--ink); border-radius: 999px; padding: .35rem .75rem; background: var(--teal); color: var(--ink); box-shadow: 2px 3px 0 var(--ink); font-size: .78rem; font-weight: 900; text-transform: uppercase; }
  .hero-product h1 { max-width: 9ch; font-size: clamp(4.7rem, 6.8vw, 6.2rem); text-shadow: 4px 5px 0 var(--ink); }
  .hero-product__copy { max-width: 44ch; font-size: clamp(1rem, 1.25vw, 1.15rem); font-weight: 700; }
  .hero-product__buy { display: flex; flex-wrap: wrap; align-items: center; gap: .8rem 1rem; margin-top: 1.45rem; }
  .hero-product__buy .price { color: white; font-size: 1.7rem; }
  .hero-product__buy form { display: flex; align-items: center; gap: .65rem; }
  .hero-product__buy select { width: auto; min-width: 150px; }
  .hero-product__details { color: white; font-size: .85rem; font-weight: 900; }
  .hero-product__promises { display: flex; flex-wrap: wrap; gap: .5rem; margin: 1.3rem 0 0; padding: 0; list-style: none; }
  .hero-product__promises li { border: 2px solid rgba(255,255,255,.7); border-radius: 999px; padding: .28rem .62rem; font-size: .7rem; font-weight: 900; text-transform: uppercase; }

  .hero-product__scene { position: absolute; z-index: 2; top: 7%; right: max(var(--page-margin), calc((100% - var(--page-width)) / 2)); width: min(58%, 820px); height: 86%; pointer-events: none; }
  .hero-product__platform { position: absolute; right: 2%; bottom: 5%; width: 80%; height: 30%; border: 4px solid var(--ink); background: var(--yellow); box-shadow: 9px 10px 0 var(--ink); clip-path: polygon(7% 0, 100% 0, 91% 100%, 0 100%); transform: rotate(-3deg); }
  .hero-part { position: absolute; z-index: 3; filter: drop-shadow(9px 12px 0 rgba(7,10,13,.78)); transform: translate3d(0, var(--parallax-y, 0), 0); }
  .hero-part img { width: 100%; height: 100%; object-fit: contain; animation: hero-float 5.8s ease-in-out infinite alternate; animation-delay: var(--part-delay); }
  .hero-part--uno { right: 10%; bottom: 18%; width: 58%; height: 48%; rotate: -5deg; }
  .hero-part--breadboard { right: 1%; top: 7%; width: 37%; height: 31%; rotate: 7deg; }
  .hero-part--oled { left: 5%; top: 8%; width: 28%; height: 29%; rotate: -8deg; }
  .hero-part--joystick { left: 0; bottom: 6%; width: 34%; height: 34%; rotate: 7deg; }
  .hero-part--sensor { right: 1%; top: 39%; width: 22%; height: 23%; rotate: 6deg; }
  .hero-part--servo { left: 32%; top: 0; width: 30%; height: 27%; rotate: -3deg; }
  .hero-product__spark { position: absolute; z-index: 5; color: var(--yellow); font-family: var(--font-display-family); font-size: clamp(2rem, 4vw, 4rem); font-weight: 900; text-shadow: 3px 3px 0 var(--ink); }
  .hero-product__spark--one { left: 43%; top: 32%; transform: rotate(10deg); }
  .hero-product__spark--two { right: 2%; bottom: 5%; }
  .hero-product__spark--three { left: 20%; bottom: 0; color: var(--teal); }
  @keyframes hero-float { from { transform: translate3d(0, var(--float-negative), 0); } to { transform: translate3d(0, var(--float-range), 0); } }

  @media (max-width: 980px) {
    .hero-product { min-height: clamp(620px, 72svh, 700px); }
    .hero-product__content { width: 52%; padding-block: 4.5rem 3rem; }
    .hero-product h1 { max-width: 7ch; font-size: clamp(3.45rem, 8vw, 4.35rem); }
    .hero-product__copy { max-width: 31ch; font-size: 1rem; }
    .hero-product__scene { top: 4%; right: -2%; width: 57%; height: 76%; opacity: .92; }
    .hero-product__platform { opacity: .88; }
    .hero-product__buy form { flex-wrap: wrap; }
  }
  @media (max-width: 680px) {
    .hero-product { min-height: 0; }
    .hero-product__content { width: 100%; padding: clamp(11.75rem, 48vw, 13.5rem) 0 1.75rem; }
    .hero-product h1 { max-width: 7ch; font-size: clamp(2.9rem, 13.5vw, 3.55rem); text-shadow: 3px 4px 0 var(--ink); }
    .hero-product__copy { max-width: 34ch; }
    .hero-product__scene { top: .25rem; right: 0; width: 100%; height: clamp(11.75rem, 48vw, 13.5rem); }
    .hero-product__platform { right: -4%; bottom: 4%; width: 74%; height: 28%; border-width: 3px; box-shadow: 5px 6px 0 var(--ink); }
    .hero-part { filter: drop-shadow(5px 7px 0 rgba(7,10,13,.68)); }
    .hero-product__buy { margin-top: 1rem; gap: .5rem; }
    .hero-product__buy .price { font-size: 1.45rem; }
    .hero-product__buy, .hero-product__buy form { align-items: stretch; flex-direction: column; width: 100%; }
    .hero-product__buy select, .hero-product__buy .button { width: 100%; }
    .hero-product__buy .button { min-height: 44px; }
    .hero-product__details { text-align: center; }
    .hero-product__promises { gap: .3rem; margin-top: .8rem; }
    .hero-product__promises li { font-size: .63rem; }
    .hero-product__spark--one { display: none; }
  }
  @media (max-width: 380px) {
    .hero-product__content { padding-top: 11.8rem; }
    .hero-product h1 { font-size: 2.85rem; }
    .hero-product__scene { height: 11.8rem; }
    .hero-product__promises li { padding-inline: .48rem; font-size: .58rem; }
  }
  @media (hover: none) { .hero-part img { animation-duration: 7s; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Product hero",
  "settings": [
    { "type": "product", "id": "product", "label": "Featured product" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Arduino starter kit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Build more. Start here." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>One compact kit. Real components. Guided projects that make Arduino click.</p>" },
    { "type": "text", "id": "button_label", "label": "Fallback button label", "default": "Shop BREADBOX" },
    { "type": "url", "id": "button_link", "label": "Fallback button link" }
  ],
  "blocks": [
    {
      "type": "component",
      "name": "Floating component",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Custom component image" },
        { "type": "select", "id": "asset", "label": "Built-in component", "options": [
          { "value": "component-arduino-uno.png", "label": "Arduino UNO" },
          { "value": "component-breadboard.png", "label": "Mini breadboard" },
          { "value": "component-oled.png", "label": "OLED display" },
          { "value": "component-joystick.png", "label": "Joystick" },
          { "value": "component-mpu6050.png", "label": "MPU6050" },
          { "value": "component-servo.png", "label": "SG90 servo" },
          { "value": "component-button.svg", "label": "Push button" },
          { "value": "component-buzzer.svg", "label": "Passive buzzer" }
        ], "default": "component-arduino-uno.png" },
        { "type": "text", "id": "label", "label": "Image alt text", "default": "Arduino component" },
        { "type": "select", "id": "position", "label": "Position", "options": [
          { "value": "uno", "label": "Main / lower right" },
          { "value": "breadboard", "label": "Upper right" },
          { "value": "oled", "label": "Upper left" },
          { "value": "joystick", "label": "Lower left" },
          { "value": "sensor", "label": "Middle right" },
          { "value": "servo", "label": "Top middle" }
        ], "default": "uno" },
        { "type": "range", "id": "float_range", "label": "Float distance", "min": 3, "max": 18, "step": 1, "unit": "px", "default": 8 },
        { "type": "range", "id": "parallax", "label": "Scroll movement", "min": -12, "max": 12, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [{
    "name": "Product hero",
    "blocks": [
      { "type": "component", "settings": { "asset": "component-arduino-uno.png", "label": "Arduino UNO R3", "position": "uno", "float_range": 7, "parallax": 4 } },
      { "type": "component", "settings": { "asset": "component-breadboard.png", "label": "170 point mini breadboard", "position": "breadboard", "float_range": 9, "parallax": -5 } },
      { "type": "component", "settings": { "asset": "component-oled.png", "label": "SSD1306 OLED display", "position": "oled", "float_range": 11, "parallax": 7 } },
      { "type": "component", "settings": { "asset": "component-joystick.png", "label": "Joystick module", "position": "joystick", "float_range": 6, "parallax": -4 } },
      { "type": "component", "settings": { "asset": "component-mpu6050.png", "label": "MPU6050 motion sensor", "position": "sensor", "float_range": 10, "parallax": 8 } },
      { "type": "component", "settings": { "asset": "component-servo.png", "label": "SG90 servo", "position": "servo", "float_range": 8, "parallax": -6 } }
    ]
  }]
}
{% endschema %}
