{% liquid
  assign featured_product = section.settings.product
  if featured_product == blank
    assign featured_product = collections.all.products.first
  endif
  assign current_variant = featured_product.selected_or_first_available_variant
%}

<section class="hero-product full-width" data-motion-section>
  <div class="hero-product__inner">
    <figure class="hero-product__visual" data-reveal="scale">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1800 | image_tag: widths: '720, 1000, 1400, 1800', sizes: '(min-width: 900px) 52vw, 94vw', loading: 'eager', alt: section.settings.image_alt }}
      {% else %}
        <img src="{{ 'hero-breadbox-build.png' | asset_url }}" alt="{{ section.settings.image_alt | escape }}" width="1124" height="1499" loading="eager">
      {% endif %}
    </figure>

    <div class="hero-product__content" data-reveal="up">
      <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h1>{{ section.settings.heading | escape }}</h1>
      <div class="hero-product__copy rte">{{ section.settings.text }}</div>

      <ul class="hero-product__features" role="list">
        <li>Arduino UNO</li>
        <li>10+ guided builds</li>
        <li>Browser uploader</li>
      </ul>

      {% if featured_product != blank %}
        <div class="hero-product__purchase" data-product-root>
          <div class="hero-product__purchase-head">
            <div>
              <span class="hero-product__purchase-label">{{ section.settings.purchase_label | escape }}</span>
              {% render 'price', product: featured_product %}
            </div>
            <span class="hero-product__stock{% unless current_variant.available %} is-unavailable{% endunless %}">
              {% if current_variant.available %}Ready to ship{% else %}Currently unavailable{% endif %}
            </span>
          </div>

          <p class="hero-product__promise">{{ section.settings.promise_text | escape }}</p>

          {% form 'product', featured_product, data-product-form: '' %}
            {% unless featured_product.has_only_default_variant %}
              <div class="hero-product__field hero-product__field--variant">
                <label for="HeroVariant-{{ section.id }}">Choose your kit</label>
                <select id="HeroVariant-{{ section.id }}" name="id">
                  {% for variant in featured_product.variants %}
                    <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" data-available="{{ variant.available }}" {% if variant == current_variant %}selected{% endif %}>{{ variant.title }} - {{ variant.price | money }}</option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% endunless %}

            <div class="hero-product__actions">
              <div class="hero-product__field hero-product__field--quantity">
                <label for="HeroQuantity-{{ section.id }}">Quantity</label>
                <input id="HeroQuantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
              </div>
              <button class="button button--yellow" type="submit" name="add" {% unless current_variant.available %}disabled{% endunless %}>
                <span>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span>
              </button>
            </div>

            {% if section.settings.show_dynamic_checkout %}
              <div class="hero-product__dynamic">{{ form | payment_button }}</div>
            {% endif %}
          {% endform %}

          <a class="hero-product__details" href="{{ featured_product.url }}">View full kit details</a>
        </div>
      {% else %}
        <div class="hero-product__purchase hero-product__purchase--fallback">
          <p>{{ section.settings.promise_text | escape }}</p>
          <a class="button button--yellow" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label | escape }}</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-product {
    overflow: clip;
    background: #f5f5f7;
    color: var(--ink);
  }
  .hero-product__inner {
    width: min(1280px, calc(100% - var(--page-margin) * 2));
    min-height: min(820px, calc(100svh - 96px));
    margin: auto;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, .92fr);
    gap: clamp(2rem, 6vw, 6.5rem);
    align-items: center;
    padding-block: clamp(3rem, 6vw, 6.5rem);
  }
  .hero-product__visual {
    min-width: 0;
    min-height: clamp(480px, 52vw, 690px);
    position: relative;
    margin: 0;
  }
  .hero-product__visual img {
    position: absolute;
    top: -52%;
    left: 44%;
    width: auto;
    max-width: none;
    height: 178%;
    object-fit: contain;
    filter: drop-shadow(22px 30px 20px rgba(7,10,13,.28));
    transform: translate3d(-50%, var(--parallax-y, 0), 0);
    transition: transform .7s cubic-bezier(.16,1,.3,1);
  }
  .hero-product__content { min-width: 0; max-width: 540px; }
  .hero-product .eyebrow { color: var(--blue); }
  .hero-product h1 {
    max-width: 10ch;
    margin-bottom: 1rem;
    font-size: clamp(3.1rem, 5vw, 5.7rem);
    line-height: .95;
    letter-spacing: 0;
  }
  .hero-product__copy {
    max-width: 38ch;
    color: #515154;
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    font-weight: 600;
    line-height: 1.5;
  }
  .hero-product__features {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin: 1.4rem 0;
    padding: 0;
    list-style: none;
  }
  .hero-product__features li {
    border-radius: 999px;
    padding: .42rem .68rem;
    background: #e8eef5;
    color: var(--blue-dark);
    font-size: .7rem;
    font-weight: 800;
  }
  .hero-product__purchase {
    border-radius: 8px;
    padding: clamp(1rem, 2vw, 1.35rem);
    background: white;
    box-shadow: 0 18px 55px rgba(7,10,13,.1);
  }
  .hero-product__purchase-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
  }
  .hero-product__purchase-label {
    display: block;
    margin-bottom: .15rem;
    color: var(--muted);
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .hero-product__purchase .price { font-size: 1.8rem; }
  .hero-product__stock {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    color: #207a3d;
    font-size: .72rem;
    font-weight: 800;
    white-space: nowrap;
  }
  .hero-product__stock::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  .hero-product__stock.is-unavailable { color: #a33b32; }
  .hero-product__promise { margin: .75rem 0 1rem; color: var(--muted); font-size: .82rem; font-weight: 600; }
  .hero-product__purchase form { display: grid; gap: .7rem; }
  .hero-product__field { display: grid; gap: .3rem; }
  .hero-product__field label { color: #515154; font-size: .68rem; font-weight: 800; text-transform: uppercase; }
  .hero-product__field select,
  .hero-product__field input { min-height: 46px; border-color: #d2d2d7; }
  .hero-product__actions { display: grid; grid-template-columns: 78px minmax(0, 1fr); gap: .65rem; align-items: end; }
  .hero-product__actions .button { width: 100%; min-height: 48px; }
  .hero-product__dynamic { margin-top: -.1rem; }
  .hero-product__dynamic .shopify-payment-button__button { min-height: 48px; border-radius: 999px; }
  .hero-product__details { display: inline-block; margin-top: .85rem; color: var(--blue); font-size: .76rem; font-weight: 750; text-decoration: none; }
  .hero-product__purchase--fallback { display: grid; gap: .7rem; }
  @media (hover: hover) {
    .hero-product__visual:hover img { transform: translate3d(-50%, calc(var(--parallax-y, 0) - 8px), 0); }
  }
  @media (max-width: 900px) {
    .hero-product__inner { grid-template-columns: minmax(0, 1fr) minmax(330px, .88fr); gap: 2rem; }
    .hero-product__visual { min-height: 500px; }
    .hero-product__visual img { top: -44%; height: 160%; }
  }
  @media (max-width: 760px) {
    .hero-product__inner { min-height: 0; grid-template-columns: 1fr; gap: .5rem; padding-block: 2rem 3rem; }
    .hero-product__visual { min-height: min(110vw, 440px); order: 1; }
    .hero-product__visual img { top: -43%; left: 50%; height: 154%; }
    .hero-product__content { max-width: none; order: 2; }
    .hero-product h1 { max-width: 12ch; font-size: clamp(2.8rem, 13vw, 4.5rem); }
  }
  @media (max-width: 420px) {
    .hero-product__inner { width: calc(100% - 28px); }
    .hero-product__visual { min-height: 340px; }
    .hero-product__visual img { top: -40%; height: 146%; }
    .hero-product__purchase-head { align-items: center; }
    .hero-product__stock { font-size: .66rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product hero",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "image_picker", "id": "image", "label": "Finished build image" },
    { "type": "text", "id": "image_alt", "label": "Image description", "default": "Completed BREADBOX Arduino project with OLED display" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Arduino project kit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "BREADBOX Arduino Kit" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Build compact games, tools and experiments with one reusable Arduino workshop.</p>" },
    { "type": "text", "id": "purchase_label", "label": "Price label", "default": "BREADBOX kit" },
    { "type": "text", "id": "promise_text", "label": "Purchase note", "default": "Hardware, guided projects and browser-based uploads included." },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show Buy Now button", "default": true },
    { "type": "text", "id": "button_label", "label": "Fallback button label", "default": "Shop BREADBOX" },
    { "type": "url", "id": "button_link", "label": "Fallback button link" }
  ],
  "presets": [{ "name": "Product hero" }]
}
{% endschema %}
