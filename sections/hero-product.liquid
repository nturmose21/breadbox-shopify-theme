{% liquid
  assign featured_product = section.settings.product
  if featured_product == blank
    assign featured_product = collections.all.products.first
  endif
  assign current_variant = featured_product.selected_or_first_available_variant
%}

<section class="hero-product full-width" data-motion-section>
  <div class="hero-product__inner">
    <header class="hero-product__intro" data-reveal="up">
      <div class="hero-product__labels">
        <span>{{ section.settings.eyebrow | escape }}</span>
        <span>Arduino UNO workshop</span>
      </div>
      <h1>{{ section.settings.heading | escape }}</h1>
      <div class="hero-product__copy rte">{{ section.settings.text }}</div>
    </header>

    <figure class="hero-product__visual" data-reveal="scale">
      <div class="hero-product__visual-label" aria-hidden="true">
        <span>Build 01</span>
        <span>Finished on your workbench</span>
      </div>
      <div class="hero-product__stage">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1800 | image_tag: widths: '720, 1000, 1400, 1800', sizes: '(min-width: 900px) 70vw, 94vw', loading: 'eager', alt: section.settings.image_alt }}
        {% else %}
          <img src="{{ 'hero-breadbox-build.png' | asset_url }}" alt="{{ section.settings.image_alt | escape }}" width="1124" height="1499" loading="eager">
        {% endif %}
      </div>
      <figcaption>{{ section.settings.caption | escape }}</figcaption>
    </figure>

    <div class="hero-product__rail" data-reveal="up">
      <div class="hero-product__promise">
        <strong>{{ section.settings.promise_heading | escape }}</strong>
        <span>{{ section.settings.promise_text | escape }}</span>
      </div>

      {% if featured_product != blank %}
        <div class="hero-product__buy" data-product-root>
          {% render 'price', product: featured_product %}
          {% form 'product', featured_product, data-product-form: '' %}
            {% if featured_product.has_only_default_variant %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% else %}
              <label class="visually-hidden" for="HeroVariant-{{ section.id }}">Choose your kit</label>
              <select id="HeroVariant-{{ section.id }}" name="id">
                {% for variant in featured_product.variants %}
                  <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" data-available="{{ variant.available }}" {% if variant == current_variant %}selected{% endif %}>{{ variant.title }} - {{ variant.price | money }}</option>
                {% endfor %}
              </select>
            {% endif %}
            <button class="button button--yellow" type="submit" name="add" {% unless current_variant.available %}disabled{% endunless %}>
              <span>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span>
              <span aria-hidden="true">&rarr;</span>
            </button>
          {% endform %}
          <a class="hero-product__details" href="{{ featured_product.url }}">See kit details</a>
        </div>
      {% else %}
        <a class="button button--yellow" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label | escape }} <span aria-hidden="true">&rarr;</span></a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-product {
    overflow: clip;
    border-bottom: 3px solid var(--ink);
    background: var(--blue);
    color: white;
  }
  .hero-product__inner {
    width: min(1280px, calc(100% - var(--page-margin) * 2));
    margin: auto;
    padding-block: clamp(2.4rem, 5vw, 4.8rem) clamp(1.2rem, 3vw, 2.2rem);
  }
  .hero-product__intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, .42fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: end;
    margin-bottom: clamp(1.5rem, 3vw, 2.2rem);
  }
  .hero-product__labels {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-block: 1px solid rgba(255,255,255,.52);
    padding-block: .55rem;
    color: white;
    font-size: .68rem;
    font-weight: 900;
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  .hero-product h1 {
    max-width: 12ch;
    margin: 0;
    color: white;
    font-size: clamp(3.7rem, 8vw, 7.4rem);
    line-height: .88;
    letter-spacing: 0;
  }
  .hero-product__copy {
    max-width: 32ch;
    justify-self: end;
    color: rgba(255,255,255,.86);
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    font-weight: 700;
    line-height: 1.48;
  }
  .hero-product__visual {
    margin: 0;
    border: 2px solid var(--ink);
    background: white;
    color: var(--ink);
  }
  .hero-product__visual-label,
  .hero-product__visual figcaption {
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: .65rem .8rem;
    font-size: .68rem;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .hero-product__visual-label { border-bottom: 2px solid var(--ink); }
  .hero-product__visual figcaption { border-top: 2px solid var(--ink); background: var(--paper-bright); }
  .hero-product__stage {
    position: relative;
    aspect-ratio: 2.25 / 1;
    overflow: hidden;
    background: var(--yellow);
  }
  .hero-product__stage::after {
    content: "BREADBOX";
    position: absolute;
    right: .65rem;
    bottom: -.08em;
    color: rgba(7,10,13,.12);
    font-family: var(--font-display-ui);
    font-size: clamp(4rem, 12vw, 11rem);
    font-weight: 900;
    line-height: .78;
    letter-spacing: 0;
  }
  .hero-product__stage img {
    position: absolute;
    z-index: 2;
    top: -75%;
    left: 50%;
    width: auto;
    max-width: none;
    height: 220%;
    object-fit: contain;
    filter: drop-shadow(16px 24px 12px rgba(7,10,13,.44));
    transform: translate3d(-50%, var(--parallax-y, 0), 0);
    transition: transform .7s cubic-bezier(.16,1,.3,1);
  }
  .hero-product__rail {
    display: grid;
    grid-template-columns: minmax(240px, .7fr) minmax(0, 1.3fr);
    border: 2px solid var(--ink);
    border-top: 0;
    background: white;
    color: var(--ink);
  }
  .hero-product__promise {
    display: grid;
    align-content: center;
    gap: .2rem;
    padding: 1rem;
    border-right: 2px solid var(--ink);
  }
  .hero-product__promise strong { font-family: var(--font-display-ui); font-size: 1.15rem; line-height: 1; }
  .hero-product__promise span { color: var(--muted); font-size: .78rem; font-weight: 750; }
  .hero-product__buy {
    min-width: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: .75rem 1rem;
    padding: .8rem 1rem;
  }
  .hero-product__buy .price { font-size: 1.55rem; }
  .hero-product__buy form { display: flex; align-items: center; gap: .55rem; }
  .hero-product__buy select { width: auto; min-width: 145px; }
  .hero-product__details { font-size: .76rem; font-weight: 900; text-transform: uppercase; }
  @media (hover: hover) {
    .hero-product__visual:hover .hero-product__stage img { transform: translate3d(-50%, calc(var(--parallax-y, 0) - 8px), 0); }
  }
  @media (max-width: 820px) {
    .hero-product__intro { grid-template-columns: 1fr; gap: .8rem; }
    .hero-product__copy { justify-self: start; }
    .hero-product__rail { grid-template-columns: 1fr; }
    .hero-product__promise { border-right: 0; border-bottom: 2px solid var(--ink); }
    .hero-product__buy { justify-content: flex-start; }
  }
  @media (max-width: 560px) {
    .hero-product__inner { width: 100%; padding: 1.4rem var(--page-margin) 0; }
    .hero-product__labels span:last-child { display: none; }
    .hero-product h1 { max-width: 9ch; font-size: clamp(3.25rem, 16vw, 4.8rem); }
    .hero-product__copy { font-size: .94rem; }
    .hero-product__visual-label span:last-child { display: none; }
    .hero-product__stage { aspect-ratio: 1.08 / 1; }
    .hero-product__stage::after { right: .25rem; font-size: 25vw; }
    .hero-product__stage img { top: -50%; height: 155%; }
    .hero-product__visual figcaption { font-size: .6rem; }
    .hero-product__buy { align-items: stretch; }
    .hero-product__buy form { width: 100%; align-items: stretch; }
    .hero-product__buy form .button { flex: 1; }
    .hero-product__buy select { min-width: 0; flex: 1; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product hero",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "image_picker", "id": "image", "label": "Finished build image" },
    { "type": "text", "id": "image_alt", "label": "Image description", "default": "Completed BREADBOX Arduino project with OLED display" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Arduino project workshop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Build small. Finish something real." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>BREADBOX turns one Arduino UNO into a workshop for compact games, tools and experiments.</p>" },
    { "type": "text", "id": "caption", "label": "Image caption", "default": "A finished mini build made with BREADBOX" },
    { "type": "text", "id": "promise_heading", "label": "Purchase heading", "default": "One kit. Many finished builds." },
    { "type": "text", "id": "promise_text", "label": "Purchase text", "default": "Hardware, guided projects and browser-based uploads." },
    { "type": "text", "id": "button_label", "label": "Fallback button label", "default": "Shop BREADBOX" },
    { "type": "url", "id": "button_link", "label": "Fallback button link" }
  ],
  "presets": [{ "name": "Product hero" }]
}
{% endschema %}
