<section class="kit-breakdown section-shell">
  <div class="kit-breakdown__media card">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1600 | image_tag: widths: '560, 800, 1200, 1600', sizes: '(min-width: 900px) 50vw, 92vw', loading: 'lazy', alt: section.settings.image.alt | default: section.settings.heading }}
    {% else %}
      <img src="{{ 'breadbox-kit-hero.jpg' | asset_url }}" alt="BREADBOX Arduino starter kit and example projects" width="1458" height="1080" loading="lazy">
    {% endif %}
  </div>
  <div class="kit-breakdown__content">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
    <div class="rte">{{ section.settings.text }}</div>
    <div class="kit-breakdown__list">
      {% for block in section.blocks %}<div class="kit-breakdown__item" {{ block.shopify_attributes }}><span>{{ forloop.index }}</span><div><h3>{{ block.settings.heading | escape }}</h3><p>{{ block.settings.text | escape }}</p></div></div>{% endfor %}
    </div>
    {% if section.settings.button_label != blank %}<a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label | escape }} →</a>{% endif %}
  </div>
</section>

{% stylesheet %}
  .kit-breakdown { display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr); gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .kit-breakdown__media { overflow: hidden; }
  .kit-breakdown__media img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .kit-breakdown__list { display: grid; gap: .85rem; margin: 1.75rem 0; }
  .kit-breakdown__item { display: grid; grid-template-columns: 44px 1fr; gap: .8rem; align-items: start; }
  .kit-breakdown__item > span { width: 40px; height: 40px; display: grid; place-items: center; border-radius: 50%; background: #e2edf7; color: var(--blue); font-family: var(--font-display-ui); font-weight: 800; }
  .kit-breakdown__item h3 { margin: 0; font-size: 1.12rem; }
  .kit-breakdown__item p { margin: .2rem 0 0; color: var(--muted); }
  @media (max-width: 820px) { .kit-breakdown { grid-template-columns: 1fr; } .kit-breakdown__media { transform: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Kit breakdown",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "A proper first electronics kit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Less hunting for parts. More making things." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>BREADBOX is designed around one repeatable setup, so every new project feels exciting instead of overwhelming.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "See the full kit" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [{ "type": "item", "name": "Kit point", "settings": [{"type":"text","id":"heading","label":"Heading","default":"Real Arduino UNO"},{"type":"text","id":"text","label":"Text","default":"A versatile board you can keep using long after the first build."}] }],
  "presets": [{ "name": "Kit breakdown", "blocks": [{"type":"item","settings":{"heading":"A complete core setup","text":"Arduino UNO, mini breadboard, OLED, controls and the parts your builds need."}},{"type":"item","settings":{"heading":"Projects that feel like products","text":"Build tiny games, useful tools and interactive gadgets you can actually show off."}},{"type":"item","settings":{"heading":"Guides made for first-timers","text":"Follow clear wiring and upload steps, then start changing the code yourself."}}] }]
}
{% endschema %}
