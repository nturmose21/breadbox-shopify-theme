<section class="kit-breakdown full-width" id="kit" data-motion-section>
  <div class="kit-breakdown__inner section-shell">
    <div class="kit-breakdown__heading">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2>{{ section.settings.heading | escape }}</h2>
        <div class="rte">{{ section.settings.text }}</div>
      </div>
      <span class="kit-breakdown__count">{{ section.blocks.size }} core parts</span>
    </div>

    <div class="kit-breakdown__grid">
      {% for block in section.blocks %}
        <article class="component-card" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | modulo: 4 | times: 60 }}ms;" {{ block.shopify_attributes }}>
          <div class="component-card__media" data-parallax="5">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 900 | image_tag: widths: '240, 480, 720, 900', sizes: '(min-width: 900px) 24vw, 45vw', loading: 'lazy', alt: block.settings.title }}
            {% else %}
              <img src="{{ block.settings.asset | asset_url }}" alt="{{ block.settings.title | escape }}" width="800" height="800" loading="lazy">
            {% endif %}
          </div>
          <div class="component-card__meta">
            <span>{{ block.settings.part_number | escape }}</span>
            <h3>{{ block.settings.title | escape }}</h3>
            {% if block.settings.quantity != blank %}<small>{{ block.settings.quantity | escape }}</small>{% endif %}
          </div>
        </article>
      {% endfor %}
    </div>

    {% if section.settings.note != blank %}<p class="kit-breakdown__note">{{ section.settings.note | escape }}</p>{% endif %}
  </div>
</section>

{% stylesheet %}
  .kit-breakdown { background: var(--paper-bright); }
  .kit-breakdown__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; }
  .kit-breakdown__heading { display: flex; justify-content: space-between; gap: 2rem; align-items: end; margin-bottom: clamp(1.5rem, 3vw, 2.5rem); }
  .kit-breakdown__heading .section-heading { max-width: 760px; margin: 0; }
  .kit-breakdown__heading .rte { max-width: 50ch; color: var(--muted); }
  .kit-breakdown__count { flex: 0 0 auto; border: 1px solid var(--ink); border-radius: var(--radius); padding: .45rem .65rem; background: var(--teal); font-family: var(--font-mono-ui); font-size: .62rem; font-weight: 700; text-transform: uppercase; }
  .kit-breakdown__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .75rem; }
  .component-card { min-width: 0; overflow: hidden; border: 1px solid #d7d4cb; border-radius: var(--radius-lg); background: var(--paper); transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease; }
  .component-card__media { height: clamp(165px, 18vw, 250px); display: grid; place-items: center; overflow: hidden; padding: clamp(.8rem, 2vw, 1.5rem); background: #ebe8df; }
  .component-card__media img { width: 100%; height: 104%; object-fit: contain; filter: drop-shadow(8px 11px 8px rgba(21,23,26,.2)); transform: translate3d(0, var(--parallax-y, 0), 0); transition: transform .35s cubic-bezier(.16,1,.3,1); }
  .component-card__meta { min-height: 108px; display: grid; align-content: start; position: relative; padding: .9rem; border-top: 1px solid #d7d4cb; }
  .component-card__meta span, .component-card__meta small { font-family: var(--font-mono-ui); text-transform: uppercase; }
  .component-card__meta span { color: var(--blue); font-size: .54rem; font-weight: 700; }
  .component-card__meta h3 { margin: .35rem 2.2rem 0 0; font-size: 1rem; line-height: 1.1; }
  .component-card__meta small { position: absolute; right: .9rem; bottom: .9rem; color: var(--muted); font-size: .52rem; font-weight: 700; }
  .kit-breakdown__note { max-width: 70ch; margin: 1.25rem 0 0; color: var(--muted); font-family: var(--font-mono-ui); font-size: .6rem; text-transform: uppercase; }
  @media (hover: hover) {
    .component-card:hover { transform: translateY(-3px); border-color: var(--ink); box-shadow: 4px 5px 0 var(--ink); }
    .component-card:hover .component-card__media img { transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04); }
  }
  @media (max-width: 900px) { .kit-breakdown__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 650px) {
    .kit-breakdown__heading { display: grid; gap: 1rem; }
    .kit-breakdown__count { width: fit-content; }
    .kit-breakdown__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .55rem; }
    .component-card__media { height: clamp(145px, 44vw, 190px); padding: .7rem; }
    .component-card__meta { min-height: 98px; padding: .7rem; }
    .component-card__meta h3 { margin-right: 0; font-size: .9rem; }
    .component-card__meta small { position: static; margin-top: .55rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Component grid",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What's in the box" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A complete little workbench." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>The reusable hardware behind every BREADBOX build, arranged and labelled for makers who want to know exactly what they are buying.</p>" },
    { "type": "text", "id": "note", "label": "Footnote", "default": "Component appearance and colour may vary slightly between production runs." }
  ],
  "blocks": [{
    "type": "component",
    "name": "Component",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Custom image" },
      { "type": "select", "id": "asset", "label": "Built-in component", "options": [
        { "value": "component-arduino-uno.png", "label": "Arduino UNO" },
        { "value": "component-breadboard.png", "label": "Mini breadboard" },
        { "value": "component-oled.png", "label": "OLED display" },
        { "value": "component-button.png", "label": "Push button" },
        { "value": "component-joystick.png", "label": "Joystick" },
        { "value": "component-mpu6050.png", "label": "MPU6050" },
        { "value": "component-servo.png", "label": "SG90 servo" },
        { "value": "component-buzzer.png", "label": "Passive buzzer" }
      ], "default": "component-arduino-uno.png" },
      { "type": "text", "id": "part_number", "label": "Part label", "default": "MCU-001" },
      { "type": "text", "id": "title", "label": "Name", "default": "UNO compatible board" },
      { "type": "text", "id": "quantity", "label": "Quantity", "default": "Qty 1" }
    ]
  }],
  "presets": [{
    "name": "Component grid",
    "blocks": [
      { "type": "component", "settings": { "asset": "component-arduino-uno.png", "part_number": "MCU-001", "title": "UNO compatible board", "quantity": "Qty 1" } },
      { "type": "component", "settings": { "asset": "component-breadboard.png", "part_number": "BRD-170", "title": "170-point breadboard", "quantity": "Qty 1" } },
      { "type": "component", "settings": { "asset": "component-oled.png", "part_number": "DSP-096", "title": "SSD1306 OLED", "quantity": "Qty 1" } },
      { "type": "component", "settings": { "asset": "component-button.png", "part_number": "BTN-006", "title": "Tactile buttons", "quantity": "Qty 5" } },
      { "type": "component", "settings": { "asset": "component-joystick.png", "part_number": "INP-023", "title": "Joystick module", "quantity": "Qty 1" } },
      { "type": "component", "settings": { "asset": "component-mpu6050.png", "part_number": "IMU-6050", "title": "Motion sensor", "quantity": "Qty 1" } },
      { "type": "component", "settings": { "asset": "component-servo.png", "part_number": "SRV-090", "title": "SG90 micro servo", "quantity": "Qty 1" } },
      { "type": "component", "settings": { "asset": "component-buzzer.png", "part_number": "SND-001", "title": "Passive buzzer", "quantity": "Qty 1" } }
    ]
  }]
}
{% endschema %}
