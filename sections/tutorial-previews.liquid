  ] }],
  "presets": [{ "name": "Tutorial previews", "blocks": [
    { "type": "tutorial", "settings": { "asset": "project-build-img_1669.jpg", "level": "OLED game", "title": "Dino Tamagotchi", "text": "Build a handheld virtual pet with real buttons and a crisp OLED display." } },
