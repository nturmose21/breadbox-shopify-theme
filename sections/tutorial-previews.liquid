    { "type": "tutorial", "settings": { "asset": "project-build-img_3559.jpg", "level": "Pocket utility", "title": "OLED calculator", "text": "Turn the same hardware into a tactile calculator you can hold." } }
  ] }]
}
{% endschema %}
