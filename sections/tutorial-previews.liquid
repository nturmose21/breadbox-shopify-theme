<section class="tutorial-previews full-width section-shell--compact" data-motion-section>
  <div class="tutorial-previews__inner">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      <div class="rte">{{ section.settings.text }}</div>
    </div>
    <div class="tutorial-previews__grid">
      {% for block in section.blocks %}
        <article class="tutorial-card" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 100 }}ms;" {{ block.shopify_attributes }}>
          <div class="tutorial-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1000 | image_tag: widths: '360, 600, 800, 1000', sizes: '(min-width: 800px) 31vw, 92vw', loading: 'lazy', alt: block.settings.title }}
            {% else %}
              <div class="tutorial-placeholder" aria-label="Project image placeholder">
                <span class="tutorial-placeholder__number">0{{ forloop.index }}</span>
                <strong>Project image</strong>
                <small>Replace in Shopify</small>
              </div>
            {% endif %}
          </div>
          <div class="tutorial-card__copy"><span>{{ block.settings.level | escape }}</span><h3>{{ block.settings.title | escape }}</h3><p>{{ block.settings.text | escape }}</p></div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .tutorial-previews { border-block: 3px solid var(--ink); background: var(--blue); color: white; }
  .tutorial-previews__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; }
  .tutorial-previews .eyebrow { color: var(--yellow); }
  .tutorial-previews .section-heading { max-width: 760px; margin-bottom: clamp(1.2rem, 3vw, 2rem); }
  .tutorial-previews .section-heading h2 { color: white; letter-spacing: 0; }
  .tutorial-previews .section-heading .rte { max-width: 42ch; color: rgba(255,255,255,.8); font-weight: 700; }
  .tutorial-previews__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .8rem; }
  .tutorial-card { min-width: 0; overflow: hidden; border: 2px solid var(--ink); border-radius: 6px; background: white; color: var(--ink); transition: transform .2s ease; }
  .tutorial-card__media { aspect-ratio: 16 / 10; border-bottom: 2px solid var(--ink); background: var(--yellow); }
  .tutorial-card__media > img { width: 100%; height: 100%; object-fit: cover; }
  .tutorial-placeholder { position: relative; width: 100%; height: 100%; display: grid; align-content: end; overflow: hidden; padding: .8rem; }
  .tutorial-placeholder::after { content: ""; position: absolute; top: 50%; right: .8rem; left: .8rem; border-top: 2px solid var(--ink); }
  .tutorial-placeholder__number { position: absolute; top: .35rem; right: .65rem; color: rgba(7,10,13,.16); font-family: var(--font-display-ui); font-size: clamp(4.4rem, 9vw, 8rem); font-weight: 900; line-height: 1; }
  .tutorial-placeholder strong { position: relative; z-index: 1; font-family: var(--font-display-ui); font-size: 1.15rem; }
  .tutorial-placeholder small { position: relative; z-index: 1; font-size: .62rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
  .tutorial-card__copy { padding: 1rem; }
  .tutorial-card__copy > span { color: var(--blue); font-size: .64rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
  .tutorial-card__copy h3 { margin: .18rem 0 .22rem; font-size: 1.32rem; letter-spacing: 0; }
  .tutorial-card__copy p { margin: 0; color: var(--muted); font-size: .8rem; font-weight: 700; line-height: 1.35; }
  @media (hover: hover) { .tutorial-card:hover { transform: translateY(-4px); } }
  @media (max-width: 760px) {
    .tutorial-previews__grid { grid-template-columns: 1fr; gap: .7rem; }
    .tutorial-card { min-height: 132px; display: grid; grid-template-columns: minmax(116px, 36%) minmax(0, 1fr); border-radius: 4px; }
    .tutorial-card__media { min-height: 128px; aspect-ratio: auto; border-right: 2px solid var(--ink); border-bottom: 0; }
    .tutorial-card__copy { align-self: center; padding: .65rem .75rem; }
    .tutorial-card__copy h3 { font-size: 1.08rem; }
    .tutorial-placeholder { padding: .55rem; }
    .tutorial-placeholder::after { right: .55rem; left: .55rem; }
    .tutorial-placeholder__number { right: .4rem; font-size: 4rem; }
    .tutorial-placeholder strong,
    .tutorial-placeholder small { display: none; }
  }
  @media (max-width: 380px) {
    .tutorial-card { grid-template-columns: 104px minmax(0, 1fr); }
    .tutorial-placeholder__number { top: .45rem; left: .5rem; }
    .tutorial-card__copy p { font-size: .76rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tutorial previews",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Project slots" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tutorial previews" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Clean placeholders now. Real project shots later.</p>" }
  ],
  "blocks": [{ "type": "tutorial", "name": "Tutorial", "settings": [
    { "type": "image_picker", "id": "image", "label": "Project image" },
    { "type": "text", "id": "level", "label": "Label", "default": "Start here" },
    { "type": "text", "id": "title", "label": "Title", "default": "Your first OLED game" },
    { "type": "text", "id": "text", "label": "Short description", "default": "Wire it, upload it, play it." }
  ] }],
  "presets": [{ "name": "Tutorial previews", "blocks": [
    { "type": "tutorial", "settings": { "level": "Start here", "title": "Your first OLED game", "text": "Wire it, upload it, play it." } },
    { "type": "tutorial", "settings": { "level": "Build next", "title": "Motion-controlled racer", "text": "Turn movement into input." } },
    { "type": "tutorial", "settings": { "level": "Explore more", "title": "Mini measurement tool", "text": "See electronics in action." } }
  ] }]
}
{% endschema %}
