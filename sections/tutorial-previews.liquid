<section class="tutorial-previews full-width section-shell--compact" data-motion-section>
  <div class="tutorial-previews__inner">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      <div class="rte">{{ section.settings.text }}</div>
    </div>
    <div class="tutorial-previews__grid">
      {% for block in section.blocks %}
        <article class="tutorial-card" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 100 }}ms;" {{ block.shopify_attributes }}>
          <div class="tutorial-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1000 | image_tag: widths: '360, 600, 800, 1000', sizes: '(min-width: 800px) 31vw, 92vw', loading: 'lazy', alt: block.settings.title }}
            {% else %}
              <div class="tutorial-placeholder" aria-label="Project image placeholder">
                <span class="tutorial-placeholder__number">0{{ forloop.index }}</span>
                <strong>Project image</strong>
                <small>Coming soon</small>
              </div>
            {% endif %}
          </div>
          <div class="tutorial-card__copy"><span>{{ block.settings.level | escape }}</span><h3>{{ block.settings.title | escape }}</h3><p>{{ block.settings.text | escape }}</p></div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .tutorial-previews { background: white; color: var(--ink); }
  .tutorial-previews__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; }
  .tutorial-previews .eyebrow { color: var(--blue); }
  .tutorial-previews .section-heading { max-width: 760px; margin: 0 auto clamp(2rem, 4vw, 3rem); text-align: center; }
  .tutorial-previews .section-heading h2 { color: var(--ink); letter-spacing: 0; }
  .tutorial-previews .section-heading .rte { max-width: 46ch; margin-inline: auto; color: var(--muted); font-weight: 600; }
  .tutorial-previews__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(1rem, 2vw, 1.5rem); }
  .tutorial-card { min-width: 0; overflow: hidden; border-radius: 8px; background: #f5f5f7; color: var(--ink); box-shadow: 0 12px 34px rgba(7,10,13,.06); transition: transform .25s ease, box-shadow .25s ease; }
  .tutorial-card__media { aspect-ratio: 4 / 3; background: #e9f0f7; }
  .tutorial-card__media > img { width: 100%; height: 100%; object-fit: cover; }
  .tutorial-placeholder { position: relative; width: 100%; height: 100%; display: grid; place-content: center; justify-items: center; gap: .3rem; overflow: hidden; padding: .8rem; color: var(--blue); }
  .tutorial-placeholder__number { color: rgba(9,100,165,.14); font-family: var(--font-display-ui); font-size: clamp(4rem, 8vw, 7rem); font-weight: 800; line-height: .9; }
  .tutorial-placeholder strong { font-family: var(--font-display-ui); font-size: 1rem; }
  .tutorial-placeholder small { color: var(--muted); font-size: .62rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
  .tutorial-card__copy { padding: 1.15rem 1.15rem 1.3rem; }
  .tutorial-card__copy > span { color: var(--blue); font-size: .64rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .tutorial-card__copy h3 { margin: .25rem 0 .3rem; font-size: 1.28rem; letter-spacing: 0; }
  .tutorial-card__copy p { margin: 0; color: var(--muted); font-size: .82rem; font-weight: 600; line-height: 1.4; }
  @media (hover: hover) { .tutorial-card:hover { transform: translateY(-4px); box-shadow: 0 18px 46px rgba(7,10,13,.1); } }
  @media (max-width: 760px) {
    .tutorial-previews__grid { grid-template-columns: 1fr; gap: .7rem; }
    .tutorial-card { min-height: 140px; display: grid; grid-template-columns: minmax(126px, 38%) minmax(0, 1fr); border-radius: 8px; }
    .tutorial-card__media { min-height: 140px; aspect-ratio: auto; }
    .tutorial-card__copy { align-self: center; padding: .65rem .75rem; }
    .tutorial-card__copy h3 { font-size: 1.08rem; }
    .tutorial-placeholder { padding: .55rem; }
    .tutorial-placeholder__number { font-size: 3.6rem; }
    .tutorial-placeholder strong { font-size: .76rem; }
    .tutorial-placeholder small { display: none; }
  }
  @media (max-width: 380px) {
    .tutorial-card { grid-template-columns: 104px minmax(0, 1fr); }
    .tutorial-placeholder__number { top: .45rem; left: .5rem; }
    .tutorial-card__copy p { font-size: .76rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tutorial previews",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Project slots" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tutorial previews" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Clean placeholders now. Real project shots later.</p>" }
  ],
  "blocks": [{ "type": "tutorial", "name": "Tutorial", "settings": [
    { "type": "image_picker", "id": "image", "label": "Project image" },
    { "type": "text", "id": "level", "label": "Label", "default": "Start here" },
    { "type": "text", "id": "title", "label": "Title", "default": "Your first OLED game" },
    { "type": "text", "id": "text", "label": "Short description", "default": "Wire it, upload it, play it." }
  ] }],
  "presets": [{ "name": "Tutorial previews", "blocks": [
    { "type": "tutorial", "settings": { "level": "Start here", "title": "Your first OLED game", "text": "Wire it, upload it, play it." } },
    { "type": "tutorial", "settings": { "level": "Build next", "title": "Motion-controlled racer", "text": "Turn movement into input." } },
    { "type": "tutorial", "settings": { "level": "Explore more", "title": "Mini measurement tool", "text": "See electronics in action." } }
  ] }]
}
{% endschema %}
