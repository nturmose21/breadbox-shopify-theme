<section class="customer-page customer-page--wide section-shell">
  <p class="eyebrow">Order details</p><h1>{{ order.name }}</h1><p>Placed {{ order.created_at | date: '%B %d, %Y' }}</p>
  <table class="customer-table"><thead><tr><th>Product</th><th>SKU</th><th>Quantity</th><th>Total</th></tr></thead><tbody>{% for line_item in order.line_items %}<tr><td><a href="{{ line_item.product.url }}">{{ line_item.title | escape }}</a>{% for discount in line_item.line_level_discount_allocations %}<br><small>{{ discount.discount_application.title }} (-{{ discount.amount | money }})</small>{% endfor %}</td><td>{{ line_item.sku }}</td><td>{{ line_item.quantity }}</td><td>{{ line_item.final_line_price | money }}</td></tr>{% endfor %}</tbody><tfoot><tr><th colspan="3">Subtotal</th><td>{{ order.line_items_subtotal_price | money }}</td></tr>{% for shipping_method in order.shipping_methods %}<tr><th colspan="3">Shipping ({{ shipping_method.title }})</th><td>{{ shipping_method.price | money }}</td></tr>{% endfor %}{% for tax_line in order.tax_lines %}<tr><th colspan="3">Tax ({{ tax_line.title }})</th><td>{{ tax_line.price | money }}</td></tr>{% endfor %}<tr><th colspan="3">Total</th><td><strong>{{ order.total_net_amount | money_with_currency }}</strong></td></tr></tfoot></table>
  <div class="customer-grid" style="margin-top: 1.5rem"><div class="customer-card"><h2>Billing address</h2>{{ order.billing_address | format_address }}</div><div class="customer-card"><h2>Shipping address</h2>{{ order.shipping_address | format_address }}</div></div>
</section>
{% schema %}{"name":"Customer order","settings":[]}{% endschema %}
