<article class="policy-page section-shell">
  <header class="policy-page__hero" data-reveal="up">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h1>{{ section.settings.heading | escape }}</h1>
    <div class="rte">{{ section.settings.intro }}</div>
  </header>

  <div class="policy-page__grid">
    {% for block in section.blocks %}
      <section class="policy-card" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 80 }}ms;" {{ block.shopify_attributes }}>
        <span>{{ forloop.index | prepend: '0' }}</span>
        <h2>{{ block.settings.heading | escape }}</h2>
        <div class="rte">{{ block.settings.text }}</div>
      </section>
    {% endfor %}
  </div>
</article>

{% stylesheet %}
  .policy-page { width: min(980px, 100%); }
  .policy-page__hero {
    max-width: 760px;
    margin-bottom: clamp(1.2rem, 4vw, 2rem);
  }
  .policy-page__hero h1 {
    max-width: 9ch;
    font-size: clamp(3.1rem, 8vw, 7.4rem);
    letter-spacing: -.04em;
  }
  .policy-page__hero .rte {
    max-width: 54ch;
    color: var(--muted);
    font-size: clamp(1rem, 1.6vw, 1.16rem);
    font-weight: 750;
  }
  .policy-page__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }
  .policy-card {
    display: grid;
    gap: .65rem;
    align-content: start;
    border: var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 3vw, 1.35rem);
    background: rgba(255,253,246,.92);
    box-shadow: var(--shadow-sm);
  }
  .policy-card span {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--yellow);
    font-size: .76rem;
    font-weight: 900;
  }
  .policy-card h2 {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.35rem);
    letter-spacing: -.02em;
  }
  .policy-card .rte {
    color: var(--muted);
    font-size: .95rem;
    font-weight: 720;
  }
  .policy-card .rte > *:last-child { margin-bottom: 0; }
  @media (max-width: 720px) {
    .policy-page__hero h1 { max-width: 11ch; font-size: clamp(2.8rem, 13vw, 4.2rem); }
    .policy-page__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Policy page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Store policy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Policy" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Clear details for ordering from BREADBOX.</p>" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Policy item",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Policy detail" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Add the policy details here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Policy page",
      "blocks": [
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
