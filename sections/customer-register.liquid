<section class="customer-page section-shell">
  <p class="eyebrow">Join the workshop</p><h1>Create an account</h1>
  {% form 'create_customer', class: 'customer-form' %}
    {{ form.errors | default_errors }}
    <label for="RegisterFirstName">First name</label><input id="RegisterFirstName" type="text" name="customer[first_name]" autocomplete="given-name">
    <label for="RegisterLastName">Last name</label><input id="RegisterLastName" type="text" name="customer[last_name]" autocomplete="family-name">
    <label for="RegisterEmail">Email</label><input id="RegisterEmail" type="email" name="customer[email]" autocomplete="email" required>
    <label for="RegisterPassword">Password</label><input id="RegisterPassword" type="password" name="customer[password]" autocomplete="new-password" required>
    <div class="customer-actions"><button class="button button--yellow" type="submit">Create account</button><a href="{{ routes.account_login_url }}">Already have an account?</a></div>
  {% endform %}
</section>
{% schema %}{"name":"Customer registration","settings":[]}{% endschema %}
