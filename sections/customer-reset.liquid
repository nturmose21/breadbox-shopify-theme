<section class="customer-page section-shell"><p class="eyebrow">Choose a new password</p><h1>Reset password</h1>{% form 'reset_customer_password', class: 'customer-form' %}{{ form.errors | default_errors }}<label for="ResetPassword">Password</label><input id="ResetPassword" type="password" name="customer[password]" required><label for="ResetPasswordConfirmation">Confirm password</label><input id="ResetPasswordConfirmation" type="password" name="customer[password_confirmation]" required><button class="button button--yellow" type="submit">Reset password</button>{% endform %}</section>
{% schema %}{"name":"Reset password","settings":[]}{% endschema %}
