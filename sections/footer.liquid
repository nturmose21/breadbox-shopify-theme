<footer class="site-footer full-width">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      {% render 'brand-mark', compact: true %}
      <p>{{ section.settings.tagline | escape }}</p>
      {% form 'customer', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="FooterEmail-{{ section.id }}">Email address</label>
        <input id="FooterEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email address" required>
        <button class="button button--yellow" type="submit">Join the build list</button>
        {% if form.posted_successfully? %}<p>You're on the list.</p>{% endif %}
        {{ form.errors | default_errors }}
      {% endform %}
    </div>
    <div class="site-footer__links">
      {% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title | escape }}</a>{% endfor %}
    </div>
    <div class="site-footer__meta">
      <p><strong>{{ section.settings.support_heading | escape }}</strong></p>
      <p>{{ section.settings.support_text | escape }}</p>
      {% if section.settings.show_payment_icons %}
        <div class="payment-icons">{% for type in shop.enabled_payment_types %}{{ type | payment_type_svg_tag }}{% endfor %}</div>
      {% endif %}
    </div>
  </div>
  <div class="site-footer__bottom">© {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. Build something brilliant.</div>
</footer>

{% stylesheet %}
  .site-footer { margin-top: var(--section-space); border-top: 4px solid var(--ink); background: var(--blue); color: white; }
  .site-footer__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; display: grid; grid-template-columns: minmax(280px, 1.4fr) 1fr 1fr; gap: clamp(2rem, 5vw, 5rem); padding-block: 4rem 3rem; }
  .site-footer__brand .brand-mark { margin-bottom: 1.25rem; }
  .newsletter-form { display: grid; grid-template-columns: 1fr auto; gap: .65rem; max-width: 540px; margin-top: 1.5rem; }
  .site-footer__links { display: grid; align-content: start; gap: .7rem; }
  .site-footer__links a { color: white; font-weight: 800; text-decoration: none; }
  .payment-icons { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1rem; }
  .payment-icons svg { width: 38px; }
  .site-footer__bottom { border-top: 2px solid rgba(255,255,255,.35); padding: 1rem var(--page-margin); text-align: center; font-size: .78rem; font-weight: 800; text-transform: uppercase; }
  @media (max-width: 820px) { .site-footer__inner { grid-template-columns: 1fr 1fr; } .site-footer__brand { grid-column: 1 / -1; } }
  @media (max-width: 560px) { .site-footer__inner { grid-template-columns: 1fr; } .site-footer__brand { grid-column: auto; } .newsletter-form { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "One small box. A whole shelf of things to build." },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" },
    { "type": "text", "id": "support_heading", "label": "Support heading", "default": "Real human support" },
    { "type": "textarea", "id": "support_text", "label": "Support text", "default": "Questions before or after your build? We are here to help." },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true }
  ]
}
{% endschema %}
