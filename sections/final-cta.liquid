{% assign cta_product = section.settings.product | default: collections.all.products.first %}
<section class="final-cta full-width" data-motion-section>
  <div class="final-cta__grid" aria-hidden="true"></div>
  <img class="final-cta__part final-cta__part--left" src="{{ 'component-servo.png' | asset_url }}" alt="" width="600" height="600" loading="lazy" data-parallax="-5">
  <img class="final-cta__part final-cta__part--right" src="{{ 'component-oled.png' | asset_url }}" alt="" width="600" height="600" loading="lazy" data-parallax="6">
  <div class="final-cta__content" data-reveal="scale">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p><h2>{{ section.settings.heading | escape }}</h2><p>{{ section.settings.text | escape }}</p>
    <a class="button button--yellow" href="{% if cta_product != blank %}{{ cta_product.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">{{ section.settings.button_label | escape }} →</a>
  </div>
</section>

{% stylesheet %}
  .final-cta { min-height: 380px; position: relative; display: grid; place-items: center; overflow: hidden; border-block: 4px solid var(--ink); background: var(--teal); }
  .final-cta__grid { position: absolute; inset: 0; opacity: .22; background-image: linear-gradient(var(--ink) 1px, transparent 1px), linear-gradient(90deg, var(--ink) 1px, transparent 1px); background-size: 30px 30px; }
  .final-cta__content { position: relative; z-index: 3; width: min(700px, calc(100% - 2rem)); padding: 3rem 1rem; text-align: center; }
  .final-cta .eyebrow { color: var(--blue-dark); }
  .final-cta h2 { font-size: clamp(2.6rem, 6vw, 5rem); }
  .final-cta__content > p:not(.eyebrow) { margin-inline: auto; max-width: 46ch; font-weight: 750; }
  .final-cta__part { position: absolute; z-index: 2; width: min(28vw, 330px); height: 82%; object-fit: contain; filter: drop-shadow(7px 9px 0 rgba(7,10,13,.65)); transform: translate3d(0, var(--parallax-y, 0), 0); }
  .final-cta__part--left { left: -3%; bottom: -18%; rotate: 13deg; }
  .final-cta__part--right { right: -2%; top: -12%; rotate: -11deg; }
  @media (max-width: 680px) { .final-cta { min-height: 420px; } .final-cta__part { width: 42vw; height: 46%; opacity: .75; } .final-cta__part--left { bottom: -10%; } .final-cta__part--right { top: -4%; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Final call to action",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your first build starts here" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to make something?" },
    { "type": "text", "id": "text", "label": "Text", "default": "Open BREADBOX and turn a handful of parts into a project you built yourself." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get BREADBOX" }
  ],
  "presets": [{ "name": "Final call to action" }]
}
{% endschema %}
