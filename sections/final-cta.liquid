{% assign cta_product = section.settings.product | default: collections.all.products.first %}
<section class="final-cta full-width" data-motion-section>
  <div class="final-cta__content" data-reveal="up">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
    <p>{{ section.settings.text | escape }}</p>
    <a class="button button--yellow" href="{% if cta_product != blank %}{{ cta_product.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">{{ section.settings.button_label | escape }}</a>
  </div>
</section>

{% stylesheet %}
  .final-cta { background: white; color: var(--ink); }
  .final-cta__content { width: min(760px, calc(100% - var(--page-margin) * 2)); margin: auto; padding-block: clamp(4rem, 9vw, 7rem); text-align: center; }
  .final-cta .eyebrow { color: var(--blue); }
  .final-cta h2 { margin-bottom: .8rem; font-size: clamp(2.8rem, 6vw, 5.6rem); letter-spacing: 0; }
  .final-cta__content > p:not(.eyebrow) { max-width: 38ch; margin: 0 auto 1.5rem; color: var(--muted); font-weight: 600; line-height: 1.5; }
{% endstylesheet %}

{% schema %}
{
  "name": "Final call to action",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Start small. Build real." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get the kit." },
    { "type": "text", "id": "text", "label": "Text", "default": "One box. Real Arduino projects. Beginner friendly." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get BREADBOX" }
  ],
  "presets": [{ "name": "Final call to action" }]
}
{% endschema %}
