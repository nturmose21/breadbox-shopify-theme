{% assign cta_product = section.settings.product | default: collections.all.products.first %}
<section class="final-cta full-width" data-motion-section>
  <div class="final-cta__content" data-reveal="up">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
    </div>
    <div class="final-cta__action">
      <p>{{ section.settings.text | escape }}</p>
      <a class="button button--yellow" href="{% if cta_product != blank %}{{ cta_product.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">{{ section.settings.button_label | escape }} <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
</section>

{% stylesheet %}
  .final-cta { border-block: 3px solid var(--ink); background: var(--blue); color: white; }
  .final-cta__content { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, .42fr); gap: clamp(1.5rem, 5vw, 5rem); align-items: end; padding-block: clamp(3rem, 7vw, 6rem); }
  .final-cta .eyebrow { color: var(--yellow); }
  .final-cta h2 { max-width: 9ch; margin: 0; color: white; font-size: clamp(3rem, 7vw, 6.8rem); letter-spacing: 0; }
  .final-cta__action { border-left: 2px solid rgba(255,255,255,.6); padding-left: 1.2rem; }
  .final-cta__action p { max-width: 32ch; color: rgba(255,255,255,.82); font-weight: 700; line-height: 1.4; }
  @media (max-width: 680px) {
    .final-cta__content { grid-template-columns: 1fr; gap: 1.4rem; padding-block: 3rem; }
    .final-cta__action { border-top: 1px solid rgba(255,255,255,.55); border-left: 0; padding: 1rem 0 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Final call to action",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Start small. Build real." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get the kit." },
    { "type": "text", "id": "text", "label": "Text", "default": "One box. Real Arduino projects. Beginner friendly." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get BREADBOX" }
  ],
  "presets": [{ "name": "Final call to action" }]
}
{% endschema %}
