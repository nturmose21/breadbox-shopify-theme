<header class="site-header full-width">
  <div class="site-header__inner">
    <a class="site-header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }} home">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 420 | image_tag: widths: '180, 260, 360, 420', sizes: '220px', loading: 'eager', alt: shop.name }}
      {% else %}
        {% render 'brand-mark', compact: true %}
      {% endif %}
    </a>

    <nav class="site-header__nav" aria-label="Primary navigation">
      {% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title | escape }}</a>{% endfor %}
    </nav>

    <div class="site-header__actions">
      <a class="header-action header-search" href="{{ routes.search_url }}">Search</a>
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          <span class="header-action" aria-label="Account">Account</span>
        </shopify-account>
      {% endif %}
      <a class="cart-link" href="{{ routes.cart_url }}" aria-label="Cart with {{ cart.item_count }} items">
        <svg aria-hidden="true" viewBox="0 0 24 24" width="23" height="23"><path d="M3 4h2l2.1 10.1a2 2 0 0 0 2 1.6h7.8a2 2 0 0 0 1.9-1.4L21 7H7" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="20" r="1.3"/><circle cx="18" cy="20" r="1.3"/></svg>
        <span>Cart</span><strong>{{ cart.item_count }}</strong>
      </a>
      <details class="mobile-menu">
        <summary aria-label="Open menu"><span></span><span></span><span></span></summary>
        <nav aria-label="Mobile navigation">
          {% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title | escape }}</a>{% endfor %}
        </nav>
      </details>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header { z-index: 20; border-bottom: 3px solid var(--ink); background: rgba(255, 253, 246, .96); }
  .site-header__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); min-height: 84px; margin: auto; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 2rem; }
  .site-header__brand { text-decoration: none; }
  .site-header__brand img { max-height: 58px; width: auto; }
  .site-header__nav { display: flex; justify-content: center; gap: clamp(1rem, 3vw, 2.2rem); }
  .site-header__nav a, .header-action { color: var(--ink); font-size: .82rem; font-weight: 900; text-decoration: none; text-transform: uppercase; }
  .site-header__nav a:hover { text-decoration: underline; text-decoration-color: var(--teal); text-decoration-thickness: 4px; }
  .site-header__actions { display: flex; align-items: center; gap: .9rem; }
  .cart-link { min-height: 42px; display: flex; align-items: center; gap: .35rem; border: 2px solid var(--ink); border-radius: 7px; padding: .4rem .65rem; background: var(--yellow); box-shadow: 2px 3px 0 var(--ink); text-decoration: none; font-size: .78rem; font-weight: 900; text-transform: uppercase; }
  .cart-link strong { min-width: 21px; min-height: 21px; display: grid; place-items: center; border-radius: 50%; background: var(--ink); color: white; font-size: .68rem; }
  .mobile-menu { display: none; position: relative; }
  .mobile-menu summary { width: 44px; height: 42px; display: grid; align-content: center; gap: 5px; border: 2px solid var(--ink); border-radius: 7px; padding: 9px; background: white; list-style: none; }
  .mobile-menu summary::-webkit-details-marker { display: none; }
  .mobile-menu summary span { height: 3px; background: var(--ink); }
  .mobile-menu nav { position: absolute; top: calc(100% + .75rem); right: 0; width: min(280px, calc(100vw - 28px)); display: grid; border: var(--line); border-radius: var(--radius); padding: .75rem; background: white; box-shadow: var(--shadow); }
  .mobile-menu nav a { padding: .8rem; border-bottom: 1px solid rgba(7,10,13,.15); font-weight: 900; text-decoration: none; text-transform: uppercase; }
  @media (max-width: 840px) { .site-header__nav, .header-action { display: none; } .site-header__inner { grid-template-columns: 1fr auto; gap: 1rem; min-height: 74px; } .mobile-menu { display: block; } .cart-link span { display: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "link_list", "id": "customer_account_menu", "label": "Customer account menu", "default": "customer-account-main-menu" }
  ]
}
{% endschema %}
