<article class="content-page section-shell">
  <p class="eyebrow">BREADBOX</p>
  <h1>{{ page.title | escape }}</h1>
  <div class="rte content-page__body">{{ page.content }}</div>
</article>

{% stylesheet %}
  .content-page { width: min(820px, 100%); }
  .content-page__body { font-size: 1.03rem; }
  .content-page__body :is(h2,h3) { margin-top: 2rem; }
  .content-page__body img { border: var(--line); border-radius: var(--radius); }
{% endstylesheet %}
{% schema %}{ "name": "Main page", "settings": [] }{% endschema %}
