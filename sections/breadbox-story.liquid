<section class="breadbox-story section-shell" data-motion-section>
  <div class="breadbox-story__header" data-reveal="up">
    <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
    <div class="rte">{{ section.settings.text }}</div>
  </div>

  <div class="breadbox-story__grid">
    {% for block in section.blocks %}
      <article class="story-card story-card--{{ forloop.index }}" data-reveal="up" style="--reveal-delay: {{ forloop.index0 | times: 100 }}ms;" {{ block.shopify_attributes }}>
        <div class="story-card__media">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: widths: '320, 520, 720, 900', sizes: '(min-width: 900px) 28vw, 92vw', loading: 'lazy', alt: block.settings.heading }}
          {% elsif block.settings.asset != 'none' %}
            <img src="{{ block.settings.asset | asset_url }}" alt="{{ block.settings.heading | escape }}" width="700" height="700" loading="lazy" data-parallax="{{ block.settings.parallax }}">
          {% endif %}
        </div>
        <div class="story-card__copy">
          <span>{{ block.settings.kicker | escape }}</span>
          <h3>{{ block.settings.heading | escape }}</h3>
          <p>{{ block.settings.text | escape }}</p>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .breadbox-story { position: relative; }
  .breadbox-story__header { display: grid; grid-template-columns: minmax(0, .9fr) minmax(280px, .56fr); gap: clamp(1rem, 4vw, 4rem); align-items: end; margin-bottom: clamp(1.25rem, 3vw, 2.2rem); }
  .breadbox-story__header h2 { max-width: 11ch; letter-spacing: -.035em; }
  .breadbox-story__header .rte { max-width: 34ch; color: var(--muted); font-weight: 750; }
  .breadbox-story__grid { display: grid; grid-template-columns: 1.12fr .88fr .88fr; gap: .9rem; }
  .story-card { min-height: 360px; position: relative; overflow: hidden; display: grid; align-content: end; border-radius: var(--radius-lg); padding: 1.1rem; background: var(--night); color: white; box-shadow: 0 24px 70px rgba(7,10,13,.18); isolation: isolate; }
  .story-card::before { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(7,10,13,.82), rgba(7,10,13,.16) 62%, rgba(7,10,13,.02)); z-index: -1; }
  .story-card--1 { min-height: 430px; background: linear-gradient(145deg, #092f4c, #071018); }
  .story-card--2 { background: linear-gradient(145deg, #fff0b8, #22c8c2); color: var(--ink); }
  .story-card--2::before { background: linear-gradient(to top, rgba(255,253,246,.72), rgba(255,253,246,.05)); }
  .story-card--3 { background: linear-gradient(145deg, #071018, #0a594f); }
  .story-card__media { position: absolute; inset: 0; display: grid; place-items: center; z-index: -2; opacity: .9; }
  .story-card__media img { width: min(78%, 440px); height: min(72%, 420px); object-fit: contain; filter: drop-shadow(0 24px 34px rgba(0,0,0,.38)); transform: translate3d(0, var(--parallax-y, 0), 0); }
  .story-card--1 .story-card__media img { width: min(86%, 540px); transform: translate3d(4%, var(--parallax-y, 0), 0) rotate(-5deg); }
  .story-card--2 .story-card__media img { width: min(76%, 360px); }
  .story-card__copy { max-width: 25rem; }
  .story-card__copy span { display: inline-flex; margin-bottom: .55rem; border-radius: 999px; padding: .32rem .55rem; background: rgba(255,255,255,.16); color: inherit; font-size: .62rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
  .story-card--2 .story-card__copy span { background: rgba(7,10,13,.1); }
  .story-card__copy h3 { margin-bottom: .35rem; font-size: clamp(1.6rem, 3vw, 3rem); letter-spacing: -.025em; }
  .story-card__copy p { max-width: 28ch; margin: 0; color: currentColor; opacity: .78; font-size: .9rem; font-weight: 750; line-height: 1.35; }
  @media (max-width: 900px) {
    .breadbox-story__header { grid-template-columns: 1fr; gap: .45rem; }
    .breadbox-story__grid { grid-template-columns: 1fr; }
    .story-card, .story-card--1 { min-height: 260px; }
  }
  @media (max-width: 560px) {
    .breadbox-story__header { margin-bottom: 1rem; }
    .story-card { min-height: 178px; border-radius: 16px; padding: .9rem; }
    .story-card__media { opacity: .72; }
    .story-card__media img { width: min(64%, 230px); height: 58%; }
    .story-card__copy span { margin-bottom: .42rem; font-size: .55rem; }
    .story-card__copy h3 { max-width: 13ch; font-size: 1.42rem; }
    .story-card__copy p { max-width: 26ch; font-size: .74rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Breadbox story",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Designed for first builds" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A tiny lab with a real product feel." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>BREADBOX turns the Arduino starter kit into a focused, visual build experience: one board, one breadboard, real parts, and projects that feel finished.</p>" }
  ],
  "blocks": [{
    "type": "feature",
    "name": "Feature card",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Custom image" },
      { "type": "select", "id": "asset", "label": "Built-in image", "options": [
        { "value": "component-arduino-uno.png", "label": "Arduino UNO" },
        { "value": "component-breadboard.png", "label": "Mini breadboard" },
        { "value": "component-oled.png", "label": "OLED display" },
        { "value": "component-joystick.png", "label": "Joystick" },
        { "value": "component-mpu6050.png", "label": "MPU6050" },
        { "value": "component-servo.png", "label": "SG90 servo" },
        { "value": "component-button.png", "label": "Push button" },
        { "value": "component-buzzer.png", "label": "Passive buzzer" },
        { "value": "none", "label": "No image" }
      ], "default": "component-arduino-uno.png" },
      { "type": "text", "id": "kicker", "label": "Kicker", "default": "01 / Hardware" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Real components" },
      { "type": "text", "id": "text", "label": "Short text", "default": "The same kind of parts makers actually use." },
      { "type": "range", "id": "parallax", "label": "Scroll movement", "min": -10, "max": 10, "step": 1, "default": 4 }
    ]
  }],
  "presets": [{
    "name": "Breadbox story",
    "blocks": [
      { "type": "feature", "settings": { "asset": "component-arduino-uno.png", "kicker": "01 / Core", "heading": "UNO at the center", "text": "Every project starts with the board beginners recognize." } },
      { "type": "feature", "settings": { "asset": "component-oled.png", "kicker": "02 / Display", "heading": "Projects with screens", "text": "OLED visuals make the builds feel alive from boot." } },
      { "type": "feature", "settings": { "asset": "component-joystick.png", "kicker": "03 / Control", "heading": "Inputs that feel like play", "text": "Buttons, joystick, motion, sound, and movement in one small kit." } }
    ]
  }]
}
{% endschema %}
