<section class="trust-strip full-width" style="--strip-bg: {{ section.settings.background }};">
  <div class="trust-strip__inner">
    {% for block in section.blocks %}
      <div class="trust-strip__item" {{ block.shopify_attributes }}>
        <span aria-hidden="true">{% case block.settings.icon %}{% when 'box' %}▣{% when 'book' %}▤{% when 'shield' %}✓{% when 'spark' %}✦{% else %}●{% endcase %}</span>
        <div><strong>{{ block.settings.heading | escape }}</strong><small>{{ block.settings.text | escape }}</small></div>
      </div>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .trust-strip { border-bottom: 4px solid var(--ink); background: var(--strip-bg); }
  .trust-strip__inner { width: min(var(--page-width), calc(100% - var(--page-margin) * 2)); margin: auto; display: grid; grid-template-columns: repeat(4, 1fr); }
  .trust-strip__item { min-height: 118px; display: flex; align-items: center; gap: .85rem; padding: 1.25rem; border-right: 2px solid var(--ink); }
  .trust-strip__item:last-child { border-right: 0; }
  .trust-strip__item > span { flex: 0 0 42px; width: 42px; height: 42px; display: grid; place-items: center; border: 2px solid var(--ink); border-radius: 50%; background: white; font-size: 1.35rem; font-weight: 900; }
  .trust-strip strong, .trust-strip small { display: block; }
  .trust-strip strong { font-size: .9rem; text-transform: uppercase; }
  .trust-strip small { margin-top: .2rem; font-weight: 700; }
  @media (max-width: 820px) {
    .trust-strip__inner { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .trust-strip__item { min-width: 0; min-height: 104px; padding: 1rem; border-bottom: 2px solid var(--ink); }
    .trust-strip__item:nth-child(even) { border-right: 0; }
    .trust-strip__item:nth-last-child(-n + 2) { border-bottom: 0; }
  }
  @media (max-width: 520px) {
    .trust-strip__inner { width: 100%; }
    .trust-strip__item { min-height: 112px; flex-direction: column; align-items: flex-start; gap: .5rem; padding: .8rem; }
    .trust-strip__item > span { flex-basis: 36px; width: 36px; height: 36px; font-size: 1rem; }
    .trust-strip strong { font-size: .76rem; line-height: 1.1; }
    .trust-strip small { font-size: .7rem; line-height: 1.25; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust strip",
  "settings": [{ "type": "color", "id": "background", "label": "Background", "default": "#22c8c2" }],
  "blocks": [{
    "type": "item", "name": "Trust item", "limit": 4,
    "settings": [
      { "type": "select", "id": "icon", "label": "Icon", "options": [{"value":"box","label":"Kit"},{"value":"book","label":"Guide"},{"value":"shield","label":"Check"},{"value":"spark","label":"Spark"}], "default": "shield" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Everything included" },
      { "type": "text", "id": "text", "label": "Text", "default": "Open the box and start building" }
    ]
  }],
  "presets": [{ "name": "Trust strip", "blocks": [{"type":"item","settings":{"icon":"box","heading":"Everything included","text":"Open the box and start building"}},{"type":"item","settings":{"icon":"book","heading":"Guided tutorials","text":"Clear steps for every project"}},{"type":"item","settings":{"icon":"shield","heading":"Beginner tested","text":"No experience needed"}},{"type":"item","settings":{"icon":"spark","heading":"Built to reuse","text":"One kit, endless experiments"}}] }]
}
{% endschema %}
